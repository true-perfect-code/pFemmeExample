    private async Task LoadShareExternallyData(string unixTS)
    {
        try
        {
            // Parameter setzen
            Dictionary<string, string> db_para = new()
            {
                { "@Case_", "SharingInfoByUnixTS>>Todo" },
                { "@UnixTS", unixTS },
            };
            BlazorCore.Services.SqlClient.ScalarModel result = await _dam!.Scalar(db_para)!; // Abfrage ausführen
            if (result != null && string.IsNullOrEmpty(result.out_err) && !string.IsNullOrEmpty(result.out_value_str)) // Resultat prüfen
            {
                // // Trennung zwischen Todo und Tasks
                // int index = result.out_value_str.IndexOf(": ");
                // Title = index >= 0 ? result.out_value_str.Substring(0, index) : result.out_value_str;
                // Text = index >= 0  ? result.out_value_str : string.Empty; 
                int index = result.out_value_str.IndexOf(": ");
                Title = index >= 0 ? result.out_value_str.Substring(0, index) : result.out_value_str;
                Text  = index >= 0 ? result.out_value_str.Substring(index + 2) : string.Empty;
            }
        }
        catch (Exception ex)
        {
            await _messageBoxService.ShowOkAsync(
                title: _appState!.T("Error"),
                message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
            );
        }
    }

    private async Task copyTextToClipboard(bool isTextCopyToClipboard)
    {
        try
        {
            if(isTextCopyToClipboard)
            {
                string text = Title ?? string.Empty;
                text = (!string.IsNullOrWhiteSpace(text) ? (text + ": " + (Text ?? string.Empty)) : "");
                if(!string.IsNullOrWhiteSpace(text))
                    await _platform.CopyTextToClipboard(text);
            }
            else
                await _platform.CopyTextToClipboard(string.Empty);
        }
        catch (Exception ex)
        {
            await _messageBoxService.ShowOkAsync(
                title: _appState!.T("Error"),
                message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
            );
        }
