@* @using p11.UI
@using BlazorCore.Models

<div class="card">
    <div class="card-header">
        <h5>@_appState!.T("Existing sharing users")</h5>
    </div>
    <div class="card-body">
        <div class="d-flex flex-column gap-4">

            @if(_appState.StorageLocation != BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col" class="py-3 ps-3" style="width: 1%; white-space: nowrap;"></th>
                                <th scope="col" class="py-3 ps-3" style="width: 1%; white-space: nowrap;"></th>
                                <th scope="col" class="py-3">@_appState!.T("Alias")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in list_SharingUsers ?? [])
                            {
                                <tr>
                                    <td class="py-2 ps-3" style="width: 1%; white-space: nowrap;">
                                        <div class="form-check">
                                            <P11Checkbox 
                                                Value="@item.IsChecked" 
                                                ValueChanged="async(bool isChecked) => {
                                                    item.IsChecked = isChecked;                
                                                    await OnCheckedSharingUser();
                                                }" 
                                                AriaLabel=@_appState!.T("Share with other user") />
                                        </div>
                                    </td>
                                    <td class="py-2 ps-3" style="width: 1%; white-space: nowrap;">   
                                    </td>
                                    <td class="py-2">
                                        <div class="d-flex align-items-center">
                                            <div class="d-flex align-items-center">
                                                <img src="@(string.IsNullOrEmpty(item.AliasImgJpegThumbnail) ? "_content/BlazorCore/img/avatar.jpg" : $"data:{BlazorCore.Utilities.DetectMimeFromBase64(item.AliasImgJpegThumbnail)};base64,{item.AliasImgJpegThumbnail}")"
                                                     alt="@(_appState.T("Avatar von") + " " + item.Alias)"
                                                     class="rounded-circle me-2"
                                                     width="40" height="40" />
                                                <strong>@item.Alias</strong>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-2">
                    <P11Button Text="@_appState.T("Save")" OnClick="OnSave" IconClass="bi bi-save" AriaLabel="@_appState.T("Save")" Title="@_appState.T("Save sharing")" />
                    <P11Button 
                        Text="@_appState.T("Cancel")" 
                        OnClick="async () => { 
                        }" 
                        IconClass="bi bi-x-lg"
                        ButtonVariant="ButtonVariant.Secondary"
                        AriaLabel="@_appState.T("Cancel sharing")" 
                        Title="@_appState.T("Cancel sharing")" />

                    <div class="ms-3"/>
                    <P11Button 
                        Text="@_appState.T("Manage")" 
                        OnClick="() => OpenModalCallback?.Invoke()" 
                        ButtonVariant="ButtonVariant.Warning"
                        IconClass="bi bi-share me-2" 
                        AriaLabel="@_appState.T("Manage sharing")" 
                        Title="@_appState.T("Manage sharing")" />
                </div>     
                
                <hr class="my-2 border-ink border-2 opacity-50">
            }

            @if(ShareExternally && (Title != null && Text != null))
            {

                <h5 class="text-ink mb-2">@_appState.T("Share via email, WhatsApp, Viber or other platforms")</h5>

                <div class="d-flex align-items-center flex-wrap">
                    <div class="mb-3 mb-md-0 me-md-4">
                        <P11Checkbox 
                            Value="IsTextCopyToClipboard"
                            ValueChanged="async(bool val) => await copyTextToClipboard(val)"
                            Label="@_appState.T("Copy text to clipboard")"
                            IsSwitch="true" />
                    </div>

                    <P11Button 
                        CssClass="btn-lg px-4 shadow-sm" 
                        Text="@_appState.T("Share Externally")"
                        OnClick="async() => await _platform.ShareText(Title ?? string.Empty, Text ?? string.Empty)"
                        IconClass="bi bi-share-fill me-2"
                        ButtonVariant="ButtonVariant.Light" />  
                </div>    
            }

        </div>
    </div>
</div>


