@using p11.UI

@if (_appState != null && _globalState != null)
{
    <div class="container py-2">
        <!-- App Info -->
        <P11HoverEffect HoverEffectVariant="HoverEffectVariant.ShadowLift">
            <div class="card shadow-sm mb-4">

                <div class="card-body text-center">
                    <h2 class="h5 card-title mb-2">@_globalState.ConfigGeneral.ApplicationName</h2>
                    <p class="text-muted mb-2">@_globalState.ConfigGeneral.AppVersion</p>
                    <p class="card-text">@(_appState!.T(_globalState.ConfigGeneral.ApplicationDescription))</p>
                </div>

                <P11AccordionNative>
                    <Title>
                        <span>@_appState!.T("Version history")</span>
                    </Title>
                    <ChildContent>
                        <div class="container">
                            <div class="card shadow-sm">
                                <div class="card-body p-0">

                                    <!-- Scrollbarer Bereich Versionsinfo -->
                                    <div class="small" style="max-height: 300px; overflow-y: auto;">
                                        @if (_appState?.Data.VersionChangeLog != null)
                                        {
                                            <table class="table table-hover mb-0 align-middle">
                                                <thead class="table-light sticky-top">
                                                    <tr>
                                                        <th style="width: 25%;">@_appState!.T("Details")</th>
                                                        <th>@_appState!.T("Changes")</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var entry in _appState.Data.VersionChangeLog)
                                                    {
                                                        string badgeClass = (entry.Version == _globalState.ConfigGeneral.AppVersion
                                                        ? "bg-success"
                                                        : "bg-secondary");

                                                        <tr>
                                                            <td>
                                                                @if (entry.Version != string.Empty)
                                                                {
                                                                    <div>
                                                                        <span class="badge @badgeClass rounded-pill">@entry.Version</span>
                                                                    </div>
                                                                }
                                                                <div class="text-muted small">@entry.Date</div>
                                                            </td>
                                                            <td>@entry.ChangeLog</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                    </div>
                                </div>
                                <div class="card-footer text-muted text-end">
                                    @_appState!.T("Current version:") <strong>@_globalState.ConfigGeneral.AppVersion</strong>
                                </div>
                            </div>
                        </div>
                    </ChildContent>
                </P11AccordionNative>

            </div>
        </P11HoverEffect>

        <!-- Entwickler/Firma Info -->
        <P11HoverEffect HoverEffectVariant="HoverEffectVariant.ShadowLift">
            <div class="card shadow-sm mb-4">
                
                <div class="card-body">

                    <!-- OUR TEAM TITLE -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h3 class="h5 card-title mb-3 text-center">@_appState!.T("Our Team")</h3>
                        </div>
                    </div>

                    <!-- GROUP IMAGE PLACEHOLDER -->
                    <div class="row mb-5">
                        <div class="col-12 text-center">
                            <img class="img-fluid rounded-3 shadow-sm mx-auto"
                                 src="_content/BlazorCore/img/team.png"
                                 alt="Team True Perfect Code"
                                 style="max-width: 500px; width: 100%; height: auto;">
                        </div>
                    </div>

                    <!-- TEAM MEMBERS NAMES & ROLES (NO IMAGES) -->
                    <div class="row text-center justify-content-center g-3 mb-4">

                        <div class="col-12 col-sm-4">
                            <h5 class="mb-1 fw-bold">Justin</h5>
                            <p class="text-muted mb-0 small">@_appState!.T("Fullstack Developer")</p>
                        </div>

                        <div class="col-12 col-sm-4">
                            <h5 class="mb-1 fw-bold">Daniel</h5>
                            <p class="text-muted mb-0 small">@_appState!.T("Senior Developer")</p>
                        </div>


                        <div class="col-12 col-sm-4">
                            <h5 class="mb-1 fw-bold">Atila</h5>
                            <p class="text-muted mb-0 small">@_appState!.T("Fullstack Developer")</p>
                        </div>

                    </div>

                    <!-- FOOTER -->
                    <div class="card-footer border-0 text-center mt-2 pt-3">
                        <p class="small text-muted my-3">
                            @_appState!.T("© 2026 True Perfect Code. All rights reserved.")
                        </p>
                    </div>
                </div>

                <!-- EULA / Privacy -->
                <P11AccordionNative>
                    <Title>
                        <span>@_appState!.T("EULA")</span>
                    </Title>
                    <ChildContent>
                        <div style="max-height: 300px; overflow-y: auto;">
                            <Eula IsHeaderHidden="true" />
                        </div>
                    </ChildContent>
                </P11AccordionNative>
                <P11AccordionNative>
                    <Title>
                        <span>@_appState!.T("Privacy")</span>
                    </Title>
                    <ChildContent>
                        <div style="max-height: 300px; overflow-y: auto;">
                            <pFemmeExample.Shared.Pages.Common.PrivacyCommon IsHeaderHidden="true" />
                        </div>
                    </ChildContent>
                </P11AccordionNative>
            </div>
        </P11HoverEffect>
    </div>
}
else
{
    <div class="alert alert-danger d-flex align-items-center py-2 px-3" role="alert">
        <i class="bi bi-exclamation-circle-fill flex-shrink-0 me-2" aria-hidden="true"></i>
        <span class="small fw-semibold">AppState or GlobalState object is null</span>
    </div>
}

@code {
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public string CssClassModalContent { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClose { get; set; }


    [Inject]
    private BlazorCore.Services.Platform.IPlatformBase _platform { get; set; } = default!;

    [Inject]
    private BlazorCore.Services.GlobalState.IGlobalStateBase? _globalState { get; set; }

    [Inject]
    private BlazorCore.Services.AppState.IAppStateBase? _appState { get; set; }


    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            StateHasChanged();
        }
    }

}
