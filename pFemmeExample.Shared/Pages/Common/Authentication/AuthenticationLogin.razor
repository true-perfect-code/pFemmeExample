    private async Task SetLocalStorage()
    {
        if (_appState?.Catalog.LocalStorage == null || _platformStorage == null) return;

        await _appState!.Log("[BLAZOR AuthenticationLogin.razor SetLocalStorage()] START");

        try
        {
            //_platform.GetCurrPlatform() != Platform.PLATFORMS.WASM
            var platform = _platform!.GetCurrPlatform();

            switch(platform)
            {
                case BlazorCore.Services.Platform.PLATFORMS.WASM:
                    // Cookie/SecureStorage auf Cloud setzen
                    await _platformStorage.SetAsync(_appState.Catalog.LocalStorage.storagelocation, ((int)BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD).ToString());
                    _appState!.UpdateStorageLocation(BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD);
                    StateHasChanged();

                    await _messageBoxService!.ShowOkAsync(
                        title: _appState!.T("Login"),
                        message: _appState.T("User account and/or password not found.")
                    );
                    return;

                // Windows, Capacitor
                default: 
                    MessageBoxResult resultStorageLocation = await _messageBoxService!.ShowYesNoCancelAsync(
                                    title: _appState!.T("Login"),
                                    message: _appState.T("User account and/or password not found.") + " " + _appState!.T("Register the account or, if the account is available locally, set the storage location to “Local” and try to log in with a local account."),
                                    yestext: _appState!.T("Local"),
                                    notext: _appState!.T("Cloud/Local"),
                                    canceltext: _appState!.T("Cloud")
                                );

                    switch (resultStorageLocation)
                    {
                        case MessageBoxResult.Yes:
                            // Cookie/SecureStorage auf Local setzen
                            await _platformStorage.SetAsync(_appState.Catalog.LocalStorage.storagelocation, ((int)BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL).ToString());
                            _appState.UpdateStorageLocation(BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL);
                            StateHasChanged();
                            break;

                        case MessageBoxResult.No:
                            // Cookie/SecureStorage auf Cloud/Local setzen
                            await _platformStorage.SetAsync(_appState.Catalog.LocalStorage.storagelocation, ((int)BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD_LOCAL).ToString());
                            _appState.UpdateStorageLocation(BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD_LOCAL);
                            StateHasChanged();
                            break;

                        case MessageBoxResult.Cancel:
                            // Cookie/SecureStorage auf Cloud setzen
                            await _platformStorage.SetAsync(_appState.Catalog.LocalStorage.storagelocation, ((int)BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD).ToString());
                            _appState.UpdateStorageLocation(BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD);
                            StateHasChanged();
                            break;

                        case MessageBoxResult.None:
                            break;
                    }
                    break;
            }
        }
        catch (Exception ex)
        {
            await _messageBoxService!.ShowOkAsync(
                title: _appState!.T("Error"),
                message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
            );
        }

        await _appState!.Log("[BLAZOR AuthenticationLogin.razor SetLocalStorage()] END");
    }

