    private async Task<BlazorCore.Services.Dam.ClientStorageModel?> PollForAuthResult(string pollingId, CancellationToken cancellationToken, int maxSeconds = 30)
    {
        BlazorCore.Services.Dam.ClientStorageModel result = new BlazorCore.Services.Dam.ClientStorageModel
        {
            WebApiToken = string.Empty,
            UnixTS = string.Empty,
        };

        bool userWantsToContinue = true;

        try
        {
            while (userWantsToContinue)
            {
                // 1. Die eigentliche Polling-Runde (z.B. 60 Sekunden)
                for (int i = 0; i < maxSeconds; i++)
                {
                    cancellationToken.ThrowIfCancellationRequested();
                    await Task.Delay(1000, cancellationToken);

                    var db_para = new Dictionary<string, string>
                    {
                        { "@Case_", "SelectByIdPClientIdent>>AuthUsers" },
                        { "@IdPClientIdent", pollingId },
                        { BlazorCore.Services.Dam.DB_CMD.NO_LOCAL, BlazorCore.Services.Dam.DB_CMD.NO_LOCAL.ToString() }
                    };

                    BlazorCore.Services.Dam.ClientStorageModel result_idptoken = await _dam!.GetTokenIDP(db_para);

                    // ERFOLGS-FALL:
                    if (result_idptoken != null && !string.IsNullOrEmpty(result_idptoken.WebApiToken))
                    {
                        result.WebApiToken = result_idptoken.WebApiToken;
                        result.UnixTS = result_idptoken.UnixTS;

                        // Hier springen wir komplett aus der Methode zurück
                        // Damit ist auch die while-Schleife beendet.
                        return result;
                    }
                }

                // 2. TIMEOUT-FALL (nach 60 Sek nichts gefunden):
                // Wir fragen den User, ob er nochmal 60 Sekunden will
                MessageBoxResult boxResult = await _messageBoxService!.ShowYesNoAsync(
                    title: _appState!.T("Info"),
                    message: _appState.T("Your sign-in process took longer than expected, and authentication was stopped. Would you like to continue account verification now?"),
                    yestext: _appState!.T("Yes"),
                    notext: _appState!.T("No")
                );

                if (boxResult != MessageBoxResult.Yes)
                {
                    // User hat "No" oder das "X" geklickt -> Schleife abbrechen
                    userWantsToContinue = false;
                }
                // Wenn "Yes", geht die while-Schleife von vorne los (neue 60 Sekunden)
            }
        }
        catch (OperationCanceledException) { /* Abbruch durch System */ }
        catch (Exception ex)
        {
            await _messageBoxService!.ShowOkAsync(
                title: _appState!.T("Error"),
                message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
            );
        }

        // Wenn wir hier landen, wurde entweder "No" geklickt oder ein Fehler trat auf
        // result enthält dann immer noch die leeren Strings von oben.
        return result;
    }

    private async Task<BlazorCore.Services.Dam.ClientStorageModel?> StartHybridAuth(string pollingId, CancellationToken cancellationToken)
    {
        await _appState!.Log("[BLAZOR pE] START StartHybridAuth");

        var tcs = new TaskCompletionSource<BlazorCore.Services.Dam.ClientStorageModel?>();

        // 1. SignalR Setup
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(_globalState!.ConfigWebapi.url_AuthHub, options =>
            {
                options.Transports = Microsoft.AspNetCore.Http.Connections.HttpTransportType.WebSockets | Microsoft.AspNetCore.Http.Connections.HttpTransportType.LongPolling;
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<BlazorCore.Services.Dam.AuthTicketDto>("ReceiveAuthTicket", dto =>
        {
            System.Diagnostics.Debug.WriteLine("SignalR: Ticket erhalten!");

            tcs.TrySetResult(new BlazorCore.Services.Dam.ClientStorageModel
            {
                WebApiToken = dto.WebApiToken,
                UnixTS = dto.UnixTS
            });
        });

        try
        {
            await _hubConnection.StartAsync(cancellationToken);
            await _hubConnection.InvokeAsync("SubscribeToAuth", pollingId, cancellationToken);

            // 2. Das intelligente Fallback-Polling
            _ = Task.Run(async () =>
            {
                try 
                {
                    // Gib SignalR 3 Sekunden Zeit, bevor wir die DB belasten
                    await Task.Delay(2000, cancellationToken); 

                    // Falls SignalR in der Zeit schon fertig war, brechen wir hier ab
                    if (tcs.Task.IsCompleted || cancellationToken.IsCancellationRequested) return;

                    System.Diagnostics.Debug.WriteLine("SignalR zu langsam oder offline. Starte Polling...");

                    var fallbackResult = await PollForAuthResult(pollingId, cancellationToken, maxSeconds: 60);

                    if (fallbackResult != null && !string.IsNullOrEmpty(fallbackResult.WebApiToken))
                    {
                        tcs.TrySetResult(fallbackResult);
                    }
                }
                catch (OperationCanceledException) { /* Task wurde sauber beendet */ }
                catch (Exception ex) { System.Diagnostics.Debug.WriteLine($"Fallback-error: {ex.Message}"); }
            }, cancellationToken);

            // Warten auf das erste verfügbare Ergebnis
            var finalResult = await tcs.Task;
            return finalResult;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"SignalR connection error: {ex.Message}");
            // Sofortiger Fallback, falls SignalR gar nicht erst verbinden kann
            return await PollForAuthResult(pollingId, cancellationToken);
        }
        finally
        {
            // WICHTIG: Verbindung immer schließen, sobald wir ein Ergebnis haben
            if (_hubConnection != null) 
            {
                await _hubConnection.StopAsync();
                await _hubConnection.DisposeAsync();
            }
        }
    }

    private async Task OnLoginClickedHtmlForm()
    {
        if (_otp == null) return;

        try
        {
            _isLoadingLoginButton = true;
            StateHasChanged();
            await Task.Delay(10);


            BlazorCore.Services.Otp.OtpParametersModel otpParameters = new();
            otpParameters.Account = Login.Account;
            otpParameters.Password = Login.Password;
            var enabled2FA = await _otp.CheckServerLoginState(otpParameters);
            if (enabled2FA)
            {
                (string OtpUserDigitInput, string OtpBackupCode, string Account, string Password) result = await _messageBoxService!.ShowAsync<pFemmeExample.Shared.Pages.Common.Otp.Otp, (string OtpUserDigitInput, string OtpBackupCode, string Account, string Password)>(
                    new
                    {
                        EmailHash = Login.Account,
                        PasswordHash = Login.Password,
                        FocusDelayMilliseconds = 150
                    },
                    title: "2FA",
                    CssClassModalContent = "tpc-form-bg-01"
                );

                if (result.OtpUserDigitInput != null)
                    Login.OtpUserDigitInput = result.OtpUserDigitInput;

                if (result.OtpBackupCode != null)
                    Login.OtpBackupCode = result.OtpBackupCode;
            }

            StateHasChanged();
            await Task.Delay(10);

            // Echtes HTML Submit ausführen
            await _jsRuntime!.InvokeVoidAsync("loginHelper.submitLoginForm");

            await Task.Delay(300);
            _appState!.UpdateAppLoadingStatus(BlazorCore.Services.AppState.APP_LOADING_STATUS.LOADING);
            _eventAggregator!.RoutesStateHasChanged(); // Wegen der Anzeige vom Loading-Status auf Routes.razor

            _isLoadingLoginButton = false;

        }
        catch (Exception ex)
        {
            await _messageBoxService!.ShowOkAsync(
                title: _appState!.T("Error"),
                message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
            );
        }
    }

    
