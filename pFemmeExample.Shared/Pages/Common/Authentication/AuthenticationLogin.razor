                        case MessageBoxResult.Cancel:
                            // Cookie/SecureStorage auf Cloud setzen
                            await _platformStorage.SetAsync(_appState.Catalog.LocalStorage.storagelocation, ((int)BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD).ToString());
                            _appState.UpdateStorageLocation(BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD);
                            StateHasChanged();
                            break;

                        case MessageBoxResult.None:
                            break;
                    }
                    break;
            }
        }
        catch (Exception ex)
        {
            await _messageBoxService!.ShowOkAsync(
                title: _appState!.T("Error"),
                message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
            );
        }

        await _appState!.Log("[BLAZOR AuthenticationLogin.razor SetCloudStorage()] END");
    }

