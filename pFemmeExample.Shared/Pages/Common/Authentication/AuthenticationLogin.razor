@using Microsoft.JSInterop
@using System.Text.Json
@using p11.UI
@using p11.UI.Services
@using BlazorCore.Services.Authentication
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject IServiceProvider ServiceProvider


@if (!IsOpenButtonHidden)
{
    <P11Button CssClass="@CssClassButton" Text="@LoginText" OnClick="() => Visible = true" />
}

@if (Visible)
{
    <P11ModalNative @bind-Visible="Visible" OnClose="OnCloseModal"
                    Id="@_idGuid"
                    NativeDevice="@_appState!.NativeDeviceType"
                    CssClassContent="@CssClassModalContent"
                    AriaLabelledby="modalTitleLogin"
                    ShowDevelopmentErrors="true"
                    Size="Size.Medium"
                    ShowHeaderSeparator="true"
                    Position="ModalPosition.Centered"
                    CloseOnOutsideClick="false"
                    CloseButtonText="@_appState.T("Back")"
                    CloseButtonIconCss="@(_appState!.NativeDeviceType == NativeDevice.IPHONE ? "bi bi-chevron-left" : null)"
                    ShowCloseButton="true">

        <HeaderContent>
            <h5 id="modalTitleLogin" class="modal-title">@_appState!.T("Login")</h5>
        </HeaderContent>
        <BodyContent>

            @if (MsgCodes != BlazorCore.MSG_CODES.Unknown && MsgCodes != BlazorCore.MSG_CODES.no_user)
            {
                <BlazorCore.Pages.AlertMsgCodes MsgCode="@MsgCodes" OnFinished="() => MsgCodes = BlazorCore.MSG_CODES.Unknown" />
            }

            @if (VisibleLanguageSelection && _appState?.Catalog.Languages != null)
            {
                <label for="idLanguage" class="form-label">@_appState!.T("Select a language")</label>
                <P11Select TItem="string" TValue="string"
                           Id="idLanguage"
                           @bind-Value="Login.Language"
                           name="language"
                           PlaceholderText="@_appState!.T("Select a language")"
                           AriaLabel="@_appState!.T("Select a language")"
                           ValidationFor="() => LoginModel.Language">
                    @foreach (var lang in _appState.Catalog.Languages)
                    {
                        <option value="@lang.Key">@lang.Value</option>
                    }
                </P11Select>
                <hr />
            }

            @if (_appState != null && _appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL)
            {
                <Component />
            }

            @if (_appState!.IsCloudConnected)
            {
                <P11AccordionNative CssClassSummary="d-flex justify-content-between align-items-center p-3 cursor-pointer">
                    <Title>
                        <span>@_appState!.T("Sign in with") <img src="/_content/BlazorCore/img/ips.jpg" style="margin-left: 25px; margin-bottom: 3px;" alt="identity providers" height="30"></span>
                    </Title>
                    <ChildContent>
                        <div class="d-flex flex-wrap justify-content-center gap-2">
                            <P11Button IsDisabled="@(_appState != null && _appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL)" HtmlType="HtmlType.Button" style="width: 110px;" Text="@_appState!.T("Microsoft")" OnClick="@(async () => { Login.Idp = IdentityProvider.Microsoft; await OnLoginClicked(); })" ButtonVariant="ButtonVariant.Primary" />
                            <P11Button IsDisabled="@(_appState != null && _appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL)" HtmlType="HtmlType.Button" style="width: 110px;" Text="@_appState!.T("Google")" OnClick="@(async () => { Login.Idp = IdentityProvider.Google; await OnLoginClicked(); })" ButtonVariant="ButtonVariant.Primary" />
                            <P11Button IsDisabled="@(_appState != null && _appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL)" HtmlType="HtmlType.Button" style="width: 110px;" Text="@_appState!.T("Apple")" OnClick="@(async () => { Login.Idp = IdentityProvider.Apple; await OnLoginClicked(); })" ButtonVariant="ButtonVariant.Primary" />
                        </div>
                    </ChildContent>
                </P11AccordionNative>
            }

            <P11AccordionNative CssClassSummary="d-flex justify-content-between align-items-center p-3 cursor-pointer" CssClass="mt-3">
                <Title>
                    <span>@_appState!.T("Sign in anonymously")</span>
                </Title>
                <ChildContent>

                    @if (!(_appState!.IsNativeApp ?? false))
                    {
                        <script>
                            window.loginHelper = {
                                submitLoginForm: function () {
                                    const form = document.getElementById("idLoginForm");
                                    if (form) {
                                        form.submit(); // echtes HTML Submit
                                    }
                                }
                            }
                        </script>
                        <!-- Diese Form sendet die Daten direkt an den Endpunkt -->
                        <form id="idLoginForm" action="@ApiEndpoint" method="post">
                            <P11Input Label="@_appState!.T("Account")"
                                      id="account"
                                      Name="account"
                                      autocomplete="off"
                                      @bind-Value="Login.Account"
                                      placeholder="@_appState!.T("Please enter your account name.")" />

                            <P11Input Label="@_appState!.T("Password")"
                                      id="idPassword"
                                      Name="password"
                                      autocomplete="off"
                                      @bind-Value="Login.Password"
                                      placeholder="@_appState!.T("Please enter your password.")"
                                      InputType="password" />

                            <P11Checkbox @bind-Value="Login.Register"
                                         Label="@(_appState!.T("Register") + (_isDisabled ? " " + _appState!.T("internet required") : ""))"
                                         Disabled="@_isDisabled"
                                         name="register" />

                            @if (Login.Register)
                            {
                                <P11Checkbox @bind-Value="Login.Termseula"
                                             Disabled="@_isDisabled"
                                             Label="@(_appState!.T("I have read and accept the Terms-Conditions and the License Agreement below.") + (_isDisabled ? " " + _appState!.T("internet required") : ""))"
                                             name="termseula" />
                            }

                            <P11Input id="otpuserdigitinput"
                                      InputType="hidden"
                                      Name="otpuserdigitinput"
                                      autocomplete="off"
                                      @bind-Value="Login.OtpUserDigitInput" />

                            <P11Input id="otpbackupcode"
                                      InputType="hidden"
                                      Name="otpbackupcode"
                                      autocomplete="off"
                                      @bind-Value="Login.OtpBackupCode" />

                            <div class="mt-4 d-flex justify-content-end gap-2">
                                <P11Button Text="@(Login.Register? _appState!.T("Register") : _appState!.T("Login"))"
                                           OnClick="OnLoginClickedHtmlForm"
                                           CssClass="btn btn-primary"
                                           IsLoading="@_isLoadingLoginButton"
                                           ButtonVariant="ButtonVariant.Primary"
                                           IsDisabled="@(Login.Register && !Login.Termseula)" />
                            </div>
                        </form>
                    }
                    else
                    {
                        <!-- Der Blazor MAUI-Teil bleibt unverändert, da hier die C#-Logik ausgeführt werden soll -->
                        <div>
                            <EditForm Model="Login" OnValidSubmit="OnLoginClicked">

                                <DynamicValidationValidator TextSelectLanguage="@_appState!.T("Please select a language.")"
                                                            TextAccountRequired="@_appState!.T("Account is required.")"
                                                            TextPasswordRequired="@_appState!.T("Password is required.")" />

                                <P11Input Label="@_appState!.T("Account")"
                                          id="idAccount"
                                          name="account"
                                          autocomplete="username"
                                          @bind-Value="Login.Account"
                                          placeholder="@_appState!.T("Please enter your account name.")"
                                          InputType="text"
                                          ValidationFor="() => Login.Account" />
                                <ValidationMessage For="() => Login.Account" />

                                <P11Input Label="@_appState!.T("Password")"
                                          id="idPassword"
                                          name="password"
                                          autocomplete="current-password"
                                          @bind-Value="Login.Password"
                                          placeholder="@_appState!.T("Please enter your password.")"
                                          InputType="password"
                                          ValidationFor="() => Login.Password" />
                                <ValidationMessage For="() => Login.Password" />

                                <P11Checkbox @bind-Value="Login.Register"
                                             Disabled="@_isDisabled"
                                             Label="@(_appState!.T("Register") + (_isDisabled ? " " + _appState!.T("internet required") : ""))"
                                             name="register" />

                                @if (Login.Register)
                                {
                                    <P11Checkbox @bind-Value="Login.Termseula"
                                                 Disabled="@_isDisabled"
                                                 Label="@(_appState!.T("I have read and accept the Terms-Conditions and the License Agreement below.") + (_isDisabled ? " " + _appState!.T("internet required") : ""))"
                                                 name="termseula" />
                                }

                                <div class="mt-4 d-flex justify-content-end gap-2">
                                    <P11Button Text="@(Login.Register? _appState!.T("Register") : _appState!.T("Login"))"
                                               HtmlType="HtmlType.Submit"
                                               IsDisabled="@(Login.Register && !Login.Termseula ? true : false)"
                                               ButtonVariant="ButtonVariant.Primary"
                                               IsLoading="@_isLoadingLoginButton"
                                               OnClick="@(e => { })" />
                                </div>
                            </EditForm>
                        </div>
                    }

                    <!-- Terms / EULA -->
                    @if (Login.Register)
                    {
                        <AuthenticationTermsEula Visible="@Login.Register" IsAcceptButtonHidden="true" />
                    }

                </ChildContent>
            </P11AccordionNative>

        </BodyContent>
    </P11ModalNative>
}

@code {
    [Inject] 
    private BlazorCore.Services.Platform.IPlatformBase? _platform { get; set; }

    [Inject]
    private BlazorCore.Services.Platform.IPlatformStorageBase? _platformStorage { get; set; }

    [Inject]
    private BlazorCore.Services.Otp.IOtpBase? _otp { get; set; }

    [Inject]
    private BlazorCore.Services.GlobalState.IGlobalStateBase? _globalState { get; set; }

    [Inject]
    private BlazorCore.Services.EventAggregator.IEventAggregator _eventAggregator { get; set; } = default!;

    [Inject]
    private BlazorCore.Services.AppState.IAppStateBase? _appState { get; set; }

    [Inject]
    private p11.UI.Services.IToastService? _toastService { get; set; }

    [Inject]
    private BlazorCore.Services.Dam.IDamBase? _dam { get; set; }

    [Inject] 
    private BlazorCore.Services.LocalQueryExecutor.ILocalQueryExecutor? _localQueryExecutor { get; set; }

    [Inject] 
    private BlazorCore.Services.LocalStorage.ILocalStorage? _localStorage { get; set; }

    [Inject] 
    private BlazorCore.Services.LocalJsonFile.ILocalJsonFile? _localJsonFile { get; set; }

    [Inject]
    private BlazorCore.Services.Authentication.IAuthenticationBase? _authentication { get; set; }

    [Inject]
    private NavigationManager? _navigationManager { get; set; }

    [Inject]
    private IMessageBoxService? _messageBoxService { get; set; }

    [Inject]
    private IJSRuntime? _jsRuntime { get; set; }



    [Parameter] public string? LoginText { get; set; }

    [Parameter] public string CssClassButton { get; set; } = "";

    [Parameter] public bool Visible { get; set; } = false;
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    [Parameter] public EventCallback OnClose { get; set; }

    [Parameter] public bool IsOpenButtonHidden { get; set; } = false;
    [Parameter] public LoginModel Login { get; set; } = new();
    [Parameter] public bool EnableRegister { get; set; } = false;
    [Parameter] public bool VisibleLanguageSelection { get; set; } = false;

    //[Parameter] public bool UseNativeFeatures { get; set; } = false;
    [Parameter] public bool CustomizedLoginFlow { get; set; } = false;

    [Parameter] public EventCallback<LoginModel> OnLogin { get; set; }

    [Parameter] public string ApiEndpoint { get; set; } = "/api/login";
    [Parameter] public string NavigateTo { get; set; } = "/";

    [Parameter] public string CssClassModalContent { get; set; } = "";
    [Parameter] public BackgroundVariant AccordionHeaderBackgroundVariant1 { get; set; } = BackgroundVariant.Light;
    [Parameter] public BackgroundVariant AccordionHeaderBackgroundVariant2 { get; set; } = BackgroundVariant.Light;

    private Guid _idGuid = Guid.NewGuid();
    private bool _isDisabled = false;
    private bool _isLoadingLoginButton = false;
    //private BlazorCore.Services.Realm.IRealmBase? _realm;
    private HubConnection? _hubConnection;
    private CancellationTokenSource? _pollingCts; // Hierher verschieben!
    private BlazorCore.MSG_CODES MsgCodes = BlazorCore.MSG_CODES.Unknown;

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(10);

        if(LoginText  == null)
        {
            LoginText = _appState!.T("Login");
        }

        _eventAggregator!.RoutesStateHasChanged(); // Wegen der Anzeige vom Loading-Status auf Routes.razor
    }

    public async ValueTask DisposeAsync()
    {
        // Durch ?. wird nur aufgerufen, wenn nicht null. 
        // Das ist threadsicherer als ein separates if-Statement.

        if (_hubConnection != null)
        {
            try 
            {
                await _hubConnection.StopAsync();
                await _hubConnection.DisposeAsync();
            } catch { /* Ignorieren beim Schließen */ }
        }

        _pollingCts?.Cancel();
        _pollingCts?.Dispose();

        _hubConnection = null;
        _pollingCts = null;
    }

    public async Task OnLoginClicked()
    {
        if (_appState?.Catalog.LocalStorage == null || _platformStorage == null || _otp == null || _globalState == null) return;

        // JS-LOG
        await _appState!.Log("[AuthenticationLogin OnLoginClicked] START");
        await _appState.Log($"[AuthenticationLogin OnLoginClicked] User account={Login.Account}");
        await _appState.Log($"[AuthenticationLogin OnLoginClicked] Is register={Login.Register}");
        await _appState.Log($"[AuthenticationLogin OnLoginClicked] Terms/eula={Login.Termseula}");
        await _appState.Log($"[AuthenticationLogin OnLoginClicked] IdP={Login.Idp}");
        await _appState.Log($"[AuthenticationLogin OnLoginClicked] IsNativeApp={_appState!.IsNativeApp}");
        await _appState.Log($"[AuthenticationLogin OnLoginClicked] IsInternetConnected={_appState.IsInternetConnected}");
        await _appState.Log($"[AuthenticationLogin OnLoginClicked] StorageLocation={_appState.StorageLocation}");

        try
        {
            // Falls Useraccount vorhanden, in die AppState legen, damit lokale DB verschlüsselt werden kann
            if (_appState != null && !string.IsNullOrEmpty(Login.Account))
            {
                // Zufallsgenerator initialisieren, da Useraccount hier bekannt
                // Bemerkung:   Gilt nur für Capacitor, WebApi und Web werden über 
                //              'pE.Utility.UnixTsGeneratorWebApi.Generate();' generiert,
                //              da dort kein lokaler Useraccount bekannt ist und DeviceID immer gleich ist (Server)  
                _appState.InitializeUnixTSUser(Login.Account);
                _appState.InitializeUnixTSDeviceId(_platform!.GetDeviceInfo());

                _appState.UpdateUserAccount(Login.Account);
            }

            if (!CustomizedLoginFlow) // Falls Login nicht hier erfolgen soll sondern im Parent
            {
                _isLoadingLoginButton = true;
                StateHasChanged();

                // Identity Provider wegen 2FA Anzeige hier setzen
                _appState!.UpdateIdP(Login.Idp.ToString().ToLower());

                if (_globalState != null && (_appState!.IsNativeApp ?? false) && Login.Idp != BlazorCore.Services.Authentication.IdentityProvider.TPC)
                {
                    // Identity Provider in SecureStorage setzen. ACHTUNG: hier ohne SecureStorageID, weil AppState.SecureStorageID nicht initialisiert ist!
                    await _platformStorage.SetAsync(_appState.Catalog.LocalStorage.idp, ((int)Login.Idp).ToString());

                    // Gerätart und Plattform ermitteln
                    string deviceTypePlatform = await _platform!.GetIdiomPlatform(); // z.B. "Desktop-WinUI"
                    await _appState.Log($"[AuthenticationLogin OnLoginClicked] nativ TPC: deviceTypePlatform = {deviceTypePlatform}", data: deviceTypePlatform);

                    // Generiere die pollingId
                    string pollingId = Guid.NewGuid().ToString();
                    await _appState.Log($"[AuthenticationLogin OnLoginClicked] nativ TPC: pollingId = {pollingId}", data: pollingId);

                    // Bündele die Client-Informationen: deviceTypePlatform|IdP|pollingId => dies wird zum WebApi Server weitergeleitet
                    var stateData = $"{deviceTypePlatform}|{Login.Idp}|{pollingId}";
                    await _appState.Log($"[AuthenticationLogin OnLoginClicked] nativ TPC: stateData", data: stateData);

                    // Kodierung in Base64 wegen Url
                    var stateDataBytes = System.Text.Encoding.UTF8.GetBytes(stateData);
                    var stateDataBase64 = Convert.ToBase64String(stateDataBytes);

                    // Auth-URL mit einheitlichem Endpunkt
                    var authUrl = $"{_globalState.ConfigGeneral.ApplicationApiUrl}/auth/external?state={Uri.EscapeDataString(stateDataBase64)}";
                    await _appState.Log($"[AuthenticationLogin OnLoginClicked] nativ TPC: authUrl = {authUrl}", data: authUrl);

                    BlazorCore.Services.Dam.ClientStorageModel? tokendata = new();

                    // Browser öffnen
                    await _platform!.AuthenticateAsync(authUrl);

                    // Polling-Loop starten
                    _pollingCts = new CancellationTokenSource();

                    // // Polling-Methode aufrufen
                    // tokendata = await PollForAuthResult(pollingId, _pollingCts.Token); // Max 15 Sekunden
                    // Wir rufen jetzt die Hybrid-Methode auf, die intern SignalR UND Polling nutzt
                    tokendata = await StartHybridAuth(pollingId, _pollingCts.Token);

                    if (tokendata != null && string.IsNullOrEmpty(tokendata.out_err))
                    {
                        if (string.IsNullOrEmpty(tokendata.WebApiToken))
                        {
                            await _messageBoxService!.ShowOkAsync(
                               title: _appState!.T("Error"),
                               message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} no_token"
                            );
                            _appState.UpdateAppLoadingStatus(BlazorCore.Services.AppState.APP_LOADING_STATUS.READY);
                            _eventAggregator!.RoutesStateHasChanged();
                        }
                        else
                        {
                            // Speichermodus hier auf CLOUD setzen, da man sich über externen Identity Provider angemeldet hat
                            await _messageBoxService!.ShowOkAsync(
                                title: _appState.T("Info"),
                                message: _appState.T("You have successfully logged in via an external identity provider.")
                            );

                            using (var aes = BlazorCore.Services.ServerShared.SecurityServerFactory.Create())
                            {
                                BlazorCore.Services.AppState.PepperClientInfo peppers = new();
                                peppers.ApplicationName = _globalState.ConfigGeneral.ApplicationName;
                                // Wir setzen 'pepper' statisch (App-Name), um anschliessend aktuelle User-Credential zu hashen
                                peppers.ApplicationNamePepper = await aes.DecryptPepperAsync();
                                await _appState.Log("[AuthenticationLogin OnLoginClicked] Generate  peppers.ApplicationNamePepper:", data: peppers.ApplicationNamePepper);

                                // Weil hier weder Account noch Passwort vorhanden sind (Anmeldung über ext. ID Provider)
                                // verwenden wir hier tokendata.WebApiToken und tokendata.UnixTS als Password und Account
                                peppers.PasHash = await aes.HashCredentialsAsync(tokendata.WebApiToken, tokendata.UnixTS, peppers.ApplicationNamePepper!);
                                await _appState.Log($"[AuthenticationLogin OnLoginClicked] Generate  peppers.PasHash: {tokendata.WebApiToken}");

                                // peppers.AccountHash = await aes.HashUsernameAsync(Login.Account, peppers.ApplicationNamePepper!);
                                peppers.AccountHash = await aes.HashUsernameAsync(tokendata.UnixTS, peppers.ApplicationNamePepper!);
                                await _appState.Log($"[AuthenticationLogin OnLoginClicked] Generate  peppers.AccountHash: {tokendata.UnixTS}");

                                byte[]? pepperPin;
                                string pepperPinString = await aes.GenerateDeterministicPepperAsync($"dynamicpepper: {peppers.PasHash} {_globalState!.ConfigGeneral.ApplicationName} {peppers.AccountHash}");
                                await _appState.Log($"[AuthenticationLogin OnLoginClicked] Generate  pepperPinString: {pepperPinString}");

                                pepperPin = await aes.DecryptPepperAsync(pepperPinString);
                                // tokendata.Email = await aes.HashUsernameAsync(Login.Account, pepperPin);
                                tokendata.Email = await aes.HashUsernameAsync(tokendata.UnixTS, pepperPin);
                                await _appState.Log($"[AuthenticationLogin OnLoginClicked] pepperPin: {pepperPin}, EmailEncrypt: {tokendata.Email}");
                            }

                            string jsonString = System.Text.Json.JsonSerializer.Serialize(tokendata);
                            _appState.ResetUserCredential();

                            // Identity Claims erstellen (Secure Storage)
                            var resultLogin = await _authentication!.Login(jsonString);
                            if (resultLogin != null && string.IsNullOrEmpty(resultLogin.out_err) && resultLogin.out_value_bool)
                            {
                                await _authentication!.GetAuthenticationStateAsync();

                                await _appState.Log($"[AuthenticationLogin OnLoginClicked] Navigate to: {NavigateTo}");

                                _appState!.ResetUserCredential(); // Wegen Wpf
                                _appState.UpdateAppLoadingStatus(BlazorCore.Services.AppState.APP_LOADING_STATUS.Unknown); // Wegen Wpf

                                _navigationManager!.NavigateTo(NavigateTo, true);
                            }
                            else
                            {
                                if (resultLogin != null && !string.IsNullOrEmpty(resultLogin.out_err))
                                {
                                    await _messageBoxService!.ShowOkAsync(
                                        title: _appState?.T("Error") ?? "Error",
                                        message: $"{_appState?.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {resultLogin.out_err}"
                                    );
                                }

                                _appState!.UpdateAppLoadingStatus(BlazorCore.Services.AppState.APP_LOADING_STATUS.READY);
                                _eventAggregator!.RoutesStateHasChanged();
                            }
                        }
                    }
                }
                else
                {
                    switch (Login.Idp)
                    {
                        case BlazorCore.Services.Authentication.IdentityProvider.TPC:

                            await _appState.Log("[AuthenticationLogin OnLoginClicked] START");

                            if(_globalState == null)
                            {
                                await _appState.Log($"[AuthenticationLogin OnLoginClicked] _globalState == null");
                                return;
                            }

                            // Registrierung ohne Internetverbindung und CLOUD-Speicherlokation nicht zulassen
                            if (!_globalState.ConfigGeneral.AllowLocalRegistration
                                && Login.Register
                                && (!_appState.IsInternetConnected || _appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL))
                            {
                                MessageBoxResult resultStorageLocation = await _messageBoxService!.ShowYesNoAsync(
                                    title: _appState!.T("Registration"),
                                    message: _appState.T("Registration is only possible if you have Internet access and have selected Cloud or Cloud/Local as the storage location!") + " " + _appState!.T("Would you like to set the storage location to cloud/local?"),
                                    yestext: _appState!.T("Cloud/Local"),
                                    notext: _appState!.T("Cancel")
                                );

                                switch (resultStorageLocation)
                                {
                                    case MessageBoxResult.Yes:
                                        // Cookie/SecureStorage auf Cloud/Local setzen
                                        await _platformStorage.SetAsync(_appState.Catalog.LocalStorage.storagelocation, ((int)BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD_LOCAL).ToString());
                                        _appState.UpdateStorageLocation(BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD_LOCAL);
                                        StateHasChanged();
                                        break;

                                    case MessageBoxResult.No:
                                    case MessageBoxResult.None:
                                        await _messageBoxService!.ShowOkAsync(
                                            title: _appState.T("Info"),
                                            message: _appState.T("Another way to create a new account is through the web browser app!")
                                        );
                                        break;
                                }

                                _isLoadingLoginButton = false;
                                return;
                            }

                            // // Prüfen, ob 2FA Anmeldung angezeigt werden soll
                            BlazorCore.Services.Otp.OtpParametersModel otpParameters = new();
                            string EmailEncrypt = Login.Account;
                            string decryptPin = string.Empty;
                            string decryptEmail = string.Empty;

                            //string pinId = string.Empty;

                            otpParameters.Account = Login.Account;
                            otpParameters.Password = Login.Password;

                            // Verschlüsselung
                            BlazorCore.Services.AppState.PepperClientInfo peppers = new();

                            //using (ServerShared.SecurityServer aes = new())
                            using (var aes = BlazorCore.Services.ServerShared.SecurityServerFactory.Create())
                            {
                                // ---
                                // Hiermit einmalig verschlüsselten Papper generieren
                                //string encryptedPepper = await aes.GenerateEncryptedPepperAsync();
                                // ---

                                peppers.ApplicationName = _globalState.ConfigGeneral.ApplicationName;

                                // Wir setzen 'pepper' statisch (App-Name), um anschliessend aktuelle User-Credential zu hashen
                                peppers.ApplicationNamePepper = await aes.DecryptPepperAsync();
                                await _appState.Log("[AuthenticationLogin OnLoginClicked] Generate  peppers.ApplicationNamePepper:", data: peppers.ApplicationNamePepper);

                                peppers.PasHash = await aes.HashCredentialsAsync(Login.Password, Login.Account, peppers.ApplicationNamePepper!);
                                await _appState.Log($"[AuthenticationLogin OnLoginClicked] Generate  peppers.PasHash: {peppers.PasHash}");

                                peppers.AccountHash = await aes.HashUsernameAsync(Login.Account, peppers.ApplicationNamePepper!);
                                await _appState.Log($"[AuthenticationLogin OnLoginClicked] Generate  peppers.AccountHash: {peppers.AccountHash}");

                                byte[]? pepperPin;
                                string pepperPinString = await aes.GenerateDeterministicPepperAsync($"dynamicpepper: {peppers.PasHash} {_globalState.ConfigGeneral.ApplicationName} {peppers.AccountHash}");
                                await _appState.Log($"[AuthenticationLogin OnLoginClicked] Generate  pepperPinString: {pepperPinString}");

                                pepperPin = await aes.DecryptPepperAsync(pepperPinString);
                                EmailEncrypt = await aes.HashUsernameAsync(Login.Account, pepperPin);
                                await _appState.Log($"[AuthenticationLogin OnLoginClicked] pepperPin: {pepperPin}, EmailEncrypt: {EmailEncrypt}");
                            }

                            bool enabled2FA = !Login.Register;
                            if (_appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL)
                            {
