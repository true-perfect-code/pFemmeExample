            { "@EmailHash", email! },
            { "@PasswordHash", pas },
            { BlazorCore.Services.Dam.DB_CMD.NO_CLOUD, BlazorCore.Services.Dam.DB_CMD.NO_CLOUD.ToString() } // Wird nur auf lokal ausgeführt
        };

        var resultCheckUser = await _dam!.Scalar(db_para);

        await _appState!.Log($"[BLAZOR AuthenticationLogin.razor CheckLocalAccount()] ExistsEmailHashPasswordHash>>AuthUsers: email={email}, pas={pas}, resultCheckUser:", data: resultCheckUser);

        if (resultCheckUser != null && string.IsNullOrEmpty(resultCheckUser.out_err))
        {
            result = resultCheckUser.out_value_bool;
        }
        else
        {
            var err = resultCheckUser != null && resultCheckUser.out_err != null ? resultCheckUser.out_err : "CheckLocalAccount>>Scalar";
            await _appState.Log(err);
            await _messageBoxService!.ShowOkAsync(
               title: _appState!.T("Error"),
               message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} err"
            );
        }
        await _appState!.Log("[BLAZOR AuthenticationLogin.razor CheckLocalAccount()] END");

        return result;
    }

    private async Task CreateLocalAccount(string email, string pas, string unixts, string idp)
    {
        if (_globalState == null || _appState == null || _dam == null || _messageBoxService == null) return;

        // JS-LOG
        await _appState!.Log("[BLAZOR AuthenticationLogin.razor CreateLocalAccount()] START");

        if (!await CheckLocalAccount(email, pas))
        {
            // Lokalen Benutzer erstellen
            Dictionary<string, string> db_para = new()
            {
                { "@Case_", "Register>>AuthUsers" },
                { "@UnixTS", unixts },
                { "@EmailHash", email },
                { "@PasswordHash", pas },
                { "@Int__Registration", "1" },
                { "@Int__TwoFA", "0" },
                { "@active", "1" },
                { "@IdP", idp },
                { BlazorCore.Services.Dam.DB_CMD.NO_CLOUD, BlazorCore.Services.Dam.DB_CMD.NO_CLOUD.ToString() },
            };

            if (_globalState.ConfigGeneral.AllowLocalRegistration)
                db_para[BlazorCore.Services.Dam.DB_CMD.ALLOW_LOCAL_REGISTRATION] = BlazorCore.Services.Dam.DB_CMD.ALLOW_LOCAL_REGISTRATION.ToString();

            // Lokaler Aufruf muss über GetTokenTPC erfolgen (nicht zu verwechseln mit GetTokenIDP)
            await _appState.Log("[BLAZOR AuthenticationLogin.razor CreateLocalAccount()] db_para", data: db_para);
            BlazorCore.Services.Dam.ClientStorageModel result_sqlite = await _dam!.GetTokenTPC(db_para);
            await _appState.Log("[BLAZOR AuthenticationLogin.razor CreateLocalAccount()] result_sqlite", data: result_sqlite);

            if (result_sqlite != null && string.IsNullOrEmpty(result_sqlite.out_err))
            {
                //Benutzer wurde erfolgreich lokal erstellt
            }
            else
            {
                await _appState.Log($"[BLAZOR AuthenticationLogin.razor CreateLocalAccount()] Err={result_sqlite!.out_err}");
                await _messageBoxService!.ShowOkAsync(
                    title: _appState!.T("Error"),
                    message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {_appState.T("The local user could not be created. If the problem persists, please contact support.")}"
                );
            }
        }

        await _appState!.Log("[BLAZOR AuthenticationLogin.razor CreateLocalAccount()] END");
    }

