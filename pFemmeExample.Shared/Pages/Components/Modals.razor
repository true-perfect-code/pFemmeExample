                            <button class="btn btn-sm btn-primary rounded-2 px-3 shadow-sm" style="font-size: 0.85rem; min-width: 80px;" @onclick="_func.SaveSettings!">@_appState.T("Save")</button>
                        }
                        else if (_appState!.NativeDeviceType == NativeDevice.WEB || _appState!.NativeDeviceType == NativeDevice.WINDOWS)
                        {
