@using BlazorCore.Services.EventAggregator
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using pFemmeExample.Shared.Services.EventAggregatorProject

<AuthorizeView>
    <Authorized Context="context">

        @* C A L E N D A R *@
        @if (_home.IsOpenModalCyclesCal)
        {
            <P11ModalNative @bind-Visible="@_home.IsOpenModalCyclesCal" OnClose="() => { }"
                            Id="@_home.IdCyclesCal"
                            NativeDevice="@_appState!.NativeDeviceType"
                            ShowHeaderSeparator="true"
                            CloseButtonText="@_appState.T("Back")"
                            CloseButtonIconCss="@(_appState!.NativeDeviceType == NativeDevice.IPHONE ? "bi bi-chevron-left" : null)"
                            AriaLabelledby="modalTitle1CyclesCal"
                            CssClassContent="tpc-form-bg-01"
                            Size="Size.Large"
                            ShowDevelopmentErrors="true">
                <HeaderContent>
                    <h5 id="modalTitle1CyclesCal" class="modal-title">@_appState!.T("Cycles Calendar")</h5>
                </HeaderContent>
                <BodyContent>

                    <pFemmeExample.Shared.Pages.Components.CyclesCal />

                </BodyContent>
            </P11ModalNative>
        }

        @* C Y C L E *@
        @if (_home.IsOpenModalCycle)
        {
            <P11ModalNative @bind-Visible="@_home.IsOpenModalCycle" OnClose="_func.CancelCycle!"
                            Id="@_home.IdCycle"
                            ShowCloseButton="false"
                            NativeDevice="@_appState!.NativeDeviceType"
                            ShowHeaderSeparator="true"
                            CloseButtonText="@_appState.T("Back")"
                            CloseButtonIconCss="@(_appState!.NativeDeviceType == NativeDevice.IPHONE ? "bi bi-chevron-left" : null)"
                            AriaLabelledby="modalTitle1Cycle"
                            CssClassContent="tpc-form-bg-01"
                            Size="Size.Large"
                            ShowDevelopmentErrors="true">
                <HeaderAction>
                    @switch (_appState!.NativeDeviceType)
                    {
                        case NativeDevice.IPHONE:
                            <button class="btn btn-link p-0 text-decoration-none fw-bold" style="color: #007aff; font-size: 1rem;" @onclick="_func.SaveCycle!">@_appState.T("Save")</button>
                            break;

                        case NativeDevice.ANDROID:
                            <button class="btn btn-link text-dark p-1" @onclick="_func.SaveCycle!"><i class="bi bi-floppy fs-4"></i></button>
                            break;
                    }
                </HeaderAction>
                <HeaderContent>
                    <h5 id="modalTitle1Cycle" class="modal-title">@_appState!.T("Cycle")</h5>
                </HeaderContent>
                <BodyContent>

                    <pFemmeExample.Shared.Pages.Components.Cycle CycleData="@_home.SelectedCycle"
                                                          OnProvideSaveAction="@(action => _func.SaveCycle = action)"
                                                          OnProvideCancelAction="@(action => _func.CancelCycle = action)" />

                </BodyContent>
                <FooterContent>
                    <div class="d-flex justify-content-end gap-2 w-100">
                        @if (_appState.NativeDeviceType == NativeDevice.MAC)
                        {
                            <button class="btn btn-sm btn-outline-secondary rounded-2 px-3 border-secondary-subtle text-dark" style="font-size: 0.85rem; min-width: 80px;" @onclick="_func.CancelCycle!">@_appState.T("Cancel")</button>
                            <button class="btn btn-sm btn-primary rounded-2 px-3 shadow-sm" style="font-size: 0.85rem; min-width: 80px;" @onclick="_func.SaveCycle!">@_appState.T("Save")</button>
                        }
                        else if (_appState!.NativeDeviceType == NativeDevice.WEB || _appState!.NativeDeviceType == NativeDevice.WINDOWS)
                        {
                            <button class="btn btn-secondary" @onclick="_func.CancelCycle!">@_appState.T("Cancel")</button>
                            <button class="btn btn-primary px-4" @onclick="_func.SaveCycle!">@_appState.T("Save")</button>
                        }
                    </div>
                </FooterContent>
            </P11ModalNative>
        }

        @* A S K   A I *@
        @if (_home.IsOpenModalAskAI)
        {
            <P11ModalNative @bind-Visible="@_home.IsOpenModalAskAI" OnClose="() => { }"
