                </HeaderContent>
                <BodyContent>

                    @* <pFemmeExample.Shared.Pages.Common.Alert OnClickOpenDoku="() => _home.IsOpenHelpSettings = true" /> *@

                    <pFemmeExample.Shared.Pages.Common.AppState.AppStateSettings OnProvideSaveAction="@(action => _func.SaveSettings = action)" OnClickCancel="() => _home.IsOpenModalSettings = false" />

                </BodyContent>

                <FooterContent>
                    <div class="d-flex justify-content-end gap-2 w-100">
                        @if (_appState.NativeDeviceType == NativeDevice.MAC)
