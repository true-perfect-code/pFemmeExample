@using p11.UI
@using Microsoft.AspNetCore.Components.Web


<pFemmeExample.Shared.Pages.Common.Help DocumentBody="@Body" Language="@Language" />

@code {
    [Inject]
    protected BlazorCore.Services.Platform.IPlatformBase _platform { get; set; } = default!;

    [Inject]
    private BlazorCore.Services.Platform.IPlatformStorageBase? _platformStorage { get; set; }

    [Inject]
    private BlazorCore.Services.GlobalState.IGlobalStateBase _globalState { get; set; } = default!;

    [Inject]
    private BlazorCore.Services.AppState.IAppStateBase _appState { get; set; } = default!;

    [Inject]
    private p11.UI.Services.IMessageBoxService? _messageBoxService { get; set; }


    public string? Language { get; set; }
    private string? Body = string.Empty;


    protected override async Task OnParametersSetAsync()
    {
        await Task.Delay(30);

        if (string.IsNullOrWhiteSpace(Language) && _appState.Catalog.LocalStorage != null && _platformStorage != null)
        {
            // Zuerst prüfen, ob AppState gesetzt ist
            if (_appState.HasSelectedLanguage())
                Language = _appState.SelectedLanguage;
            else
            {
                // Dann Cookie/SecureStorage prüfen
                var language = await _platformStorage.GetAsync(_appState.Catalog.LocalStorage.language);
                if (language != null && string.IsNullOrEmpty(language.out_err) && !string.IsNullOrEmpty(language.out_value_str))
                    Language = language.out_value_str; // Sprache aus Cookie/SecurStorage setzen
                else // ...ansonsten Standardsprache setzen
                {
                    if (language != null && !string.IsNullOrEmpty(language.out_err))
                    {
                        await _messageBoxService!.ShowOkAsync(
                            title: _appState?.T("Error") ?? "Error",
                            message: $"{_appState?.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {language.out_err}"
                        );
                    }

                    Language = _globalState!.ConfigGeneral.DefaultLanguage;
                }
            }
        }

        switch (Language)
        {
            case "EN":
                Body =$@"
1. Sharing (Data Sharing):
- The Sharing form is used to define a base of users with whom data is intended to be shared.
- Once a user is listed here, they can be selected for a specific To-Do entry under the Sharing option.
- The selected user automatically receives full access to that To-Do entry (including modification rights), as if it were their own.

2. Searching and Adding Users:
- Since the app does not store readable personal data (like email addresses), user identification is done exclusively via the <b>Alias Name</b>.
- The Alias Name must have been previously set up by the respective user in their profile and must be unique.
- Searching for another user is done via the search field in the Sharing form, using their Alias Name.
- After a successful search, the user's stored profile picture will be displayed.
_content/Shared/img/video_SharingNewUser.gif

3. Sharing Request:
- After finding the desired user, a <b>Sharing Request</b> can be sent to them.
- The other user can accept or reject this request within their app, preventing repeated unwanted applications.
- Once a sharing request is accepted, data can be shared in both directions.
_content/Shared/img/video_SharingAccept.gif

4. Sharing Data and Ending Access:
- Data sharing is not automatic upon request acceptance; you must separately activate sharing for the specific To-Do entry under its Sharing option.
- A Sharing entry can be deleted unilaterally at any time by either party.
- By deleting the entry, the previously shared To-Do items will no longer be displayed to the other person.
_content/Shared/img/video_SharingTodo.gif

Note
A detailed description of the application can be found in our linked user manual
https://true-perfect-code.ch/_doc/PROJECTAPPLICATIONNAME/PROJECTAPPLICATIONNAMEUserGuide_{_appState.SelectedLanguage}.pdf
";
                break;

            case "DE":
