                        </HeaderContent>
                        <BodyContent>

                            <TestSolution4.Shared.Pages.Help.HelpExportImport />

                        </BodyContent>
                    </P11ModalNative> 
                }
            }
            else
            {
                <P11FloatingPanel Id="@_home.IdHelpExportImport"
                                    Title="@_appState!.T("Help Export/Import")"
                                    @bind-Visible="@_home.IsOpenHelpExportImport"
                                    EnableDragDrop="true"
                                    OnClose="@(() => _home.IsOpenHelpExportImport = false)">
                    <ChildContent>
                        <TestSolution4.Shared.Pages.Help.HelpExportImport />
                    </ChildContent>
                </P11FloatingPanel>            
            }
        }

        @* 2 F A   S E T U P *@
        @if(_home.IsOpenModal2FASetup)
        {
            <P11ModalNative @bind-Visible="@_home.IsOpenModal2FASetup" OnClose="() => {}"
