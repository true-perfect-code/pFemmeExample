                    ShowHeaderSeparator="true"
                    CloseButtonText="@_appState.T("Back")"
                    CloseButtonIconCss="@(_appState!.NativeDeviceType == NativeDevice.IPHONE ? "bi bi-chevron-left" : null)"
                    AriaLabelledby="modalTitle1Sharing"
                    CssClassContent="tpc-form-bg-01"
                    Size="Size.Large"
                    ShowDevelopmentErrors="true">
                <HeaderAction>
                    @switch(_appState!.NativeDeviceType)
                    {
                        case NativeDevice.IPHONE:
                            <button class="btn btn-link p-0 text-decoration-none fw-bold" style="color: #007aff; font-size: 1rem;" @onclick="_saveExportImport!">@_appState.T("Exp./Imp.")</button>
                            break;

                        case NativeDevice.ANDROID:
                            <button class="btn btn-link text-dark p-1" @onclick="_saveExportImport!"><i class="bi bi-arrow-down-up fs-4"></i></button>
                            break;
                    }
                </HeaderAction>
                <HeaderContent>
                    <h5 id="modalTitle1Sharing" class="modal-title">@_appState.T("Export/Import")</h5>
                </HeaderContent>
                <BodyContent>
            
                    <TestSolution4.Shared.Pages.Common.Alert OnClickOpenDoku="() => _home.IsOpenHelpExportImport = true" />

                    <TestSolution4.Shared.Pages.Common.ExportImport 
                                    DataContainer="@_home.ContainerExportimport"
                                    CssClassModalContent="tpc-form-bg-01"
                                    HideExportPanel="@(_home.ContainerExportimport.Any() ? false : true)" 
                                    OnClickCancel="() => _home.IsOpenModalExportImport = false"
                                    OnImport="(data) => OnImportData(data)"
                                    OnProvideSaveAction="@(action => _saveExportImport = action)" />

                </BodyContent>
            </P11ModalNative>

            @* H E L P   E X P O R T  /  I M P O R T *@
            @if(_appState != null && _appState!.IsPhone)
            {
                @if(_home.IsOpenHelpExportImport)
                {
                    <P11ModalNative @bind-Visible="@_home.IsOpenHelpExportImport" OnClose="async() => {}"
                            Id="@_home.IdHelpExportImport"
                            IsHeaderHide="@_home.IsHeaderHide"
                            IsFooterHide="@_home.IsFooterHide"
                            NativeDevice="@_appState!.NativeDeviceType"
                            ShowHeaderSeparator="true"
                            CloseButtonText="@_appState.T("Back")"
                            CloseButtonIconCss="@(_appState!.NativeDeviceType == NativeDevice.IPHONE ? "bi bi-chevron-left" : null)"
