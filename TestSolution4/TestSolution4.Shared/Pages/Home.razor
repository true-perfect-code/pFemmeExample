                    <TestSolution4.Shared.Pages.Common.Otp.OtpSetup OnClickCancel="() => _home.IsOpenModal2FASetup = false" QrWidth="250" />

                </BodyContent>
            </P11ModalNative>
        }

        @* 2 F A   R E V O K E *@
        @if(_home.IsOpenModal2FARevoke)
        {
            <P11ModalNative @bind-Visible="@_home.IsOpenModal2FARevoke" OnClose="() => {}"
