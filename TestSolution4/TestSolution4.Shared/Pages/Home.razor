            @* H E L P   S H A R I N G *@
            @if(_appState != null && _appState!.IsPhone)
            {
                @if(_home.IsOpenHelpSharing)
                {
                    <P11ModalNative @bind-Visible="@_home.IsOpenHelpSharing" OnClose="async() => {}"
                            Id="@_home.IdHelpSharing"
