                    AriaLabelledby="modalTitleAbout"
                    CssClassContent="tpc-form-bg-01"
                    Size="Size.Large"
                    ShowDevelopmentErrors="true">
                <HeaderContent>
                    <h5 id="modalTitleAbout" class="modal-title">@_appState!.T("About")</h5>
                </HeaderContent>
                <BodyContent>

                    <TestSolution4.Shared.Pages.Common.About OnClose="@(() => _home.IsOpenModalAbout = false)" CssClassModalContent="tpc-form-bg-01" />

                </BodyContent>
            </P11ModalNative>
        }

        @* D O N A T E *@
        @if(_home.IsOpenModalDonate)
        {
            <P11ModalNative @bind-Visible="@_home.IsOpenModalDonate" OnClose="() => {}"
                    Id="@_home.IdDonate"
                    NativeDevice="@_appState!.NativeDeviceType"
                    ShowHeaderSeparator="true"
                    CloseButtonText="@_appState.T("Back")"
                    CloseButtonIconCss="@(_appState!.NativeDeviceType == NativeDevice.IPHONE ? "bi bi-chevron-left" : null)"
