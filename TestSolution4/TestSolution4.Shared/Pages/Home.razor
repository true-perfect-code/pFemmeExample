                </HeaderContent>
                <BodyContent>
            
                    <TestSolution4.Shared.Pages.Common.Alert OnClickOpenDoku="() => _home.IsOpenHelp2FA = true" />

                    <TestSolution4.Shared.Pages.Common.Otp.Otp OnSecretEntered="OnClick_2FARevoke" />

                </BodyContent>
            </P11ModalNative>
        }

        @* H E L P   2 F A / 2 F A  R E V O K E *@
        @if(_appState != null && _appState!.IsPhone)
        {
            @if(_home.IsOpenHelp2FA)
            {
                <P11ModalNative @bind-Visible="@_home.IsOpenHelp2FA" OnClose="async() => {}"
                        Id="@_home.IdHelp2FA"
                        IsHeaderHide="@_home.IsHeaderHide"
                        IsFooterHide="@_home.IsFooterHide"
