                            CloseButtonText="@_appState.T("Back")"
                            CloseButtonIconCss="@(_appState!.NativeDeviceType == NativeDevice.IPHONE ? "bi bi-chevron-left" : null)"
                            AriaLabelledby="specific-position-panel-settings"
                            CssClassContent="tpc-form-bg-01"
                            Size="Size.Large"
                            ShowDevelopmentErrors="true">
                        <HeaderContent>
                            <h5 id="specific-position-panel-settings" class="modal-title">@_appState.T("Help Sharing")</h5>
                        </HeaderContent>
                        <BodyContent>

                            <TestSolution4.Shared.Pages.Help.HelpSharing />

                        </BodyContent>
                    </P11ModalNative> 
                }
            }
            else
