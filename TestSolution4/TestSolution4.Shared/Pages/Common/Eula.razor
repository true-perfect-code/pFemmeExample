    [Parameter]
    public bool IsHeaderHidden { get; set; } = false;

    private string? Header = string.Empty;
    private string? Body = string.Empty;
    //private string[]? BodyBlocks { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await Task.Delay(30);

        if (string.IsNullOrWhiteSpace(Language) && _appState.Catalog.LocalStorage != null)
        {
            // Zuerst prüfen, ob AppState gesetzt ist
            if (_appState.HasSelectedLanguage())
                Language = _appState.SelectedLanguage;
            else
            {
                // Dann Cookie/SecureStorage prüfen
                var result = await _platform!.GetAsync(_appState.Catalog.LocalStorage.language);
                if (result != null && string.IsNullOrEmpty(result.out_err) && !string.IsNullOrEmpty(result.out_value_str))
                    Language = result.out_value_str; // Sprache aus Cookie/SecurStorage setzen
                else // ...ansonsten Standardsprache setzen
                {
                    if (result != null && !string.IsNullOrEmpty(result.out_err))
                    {
                        await _messageBoxService!.ShowOkAsync(
                            title: _appState?.T("Error") ?? "Error",
                            message: $"{_appState?.T(_globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!")} {result.out_err}"
                        );
                    }

                    Language = _globalState!.ConfigGeneral.DefaultLanguage;
                }
            }
