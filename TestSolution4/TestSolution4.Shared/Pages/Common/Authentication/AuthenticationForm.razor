    private async Task OnClick_DeleteCloudData()
    {
        // JS-LOG
        await _appState!.Log("START [AuthenticationForm.razor] OnClick_DeleteCloudData");

        if (OnChangeVisible.HasDelegate)
        {
            await OnChangeVisible.InvokeAsync(false);
            await Task.Delay(30);
            StateHasChanged();
        }

        await Task.Delay(30);
        StateHasChanged();

        MessageBoxResult result = await _messageBoxService.ShowYesNoAsync(
            title: _appState!.T("Confirmation"),
            message: _appState!.T("Do you want to delete your cloud data (cloud account will not be deleted)?"),
            yestext: @_appState!.T("Yes"),
            notext: @_appState!.T("No")
        );

        switch (result)
        {
            case MessageBoxResult.Yes:
                // Parameter setzen
                Dictionary<string, string> db_para = new()
                {
                    { "@Case_", "DeleteCloudData" },
                    { "@UnixTS", _appState!.UnixTS },
                };
                await _appState.Log($"db_para", data: db_para);
                BlazorCore.Services.SqlClient.ScalarModel result_delete = await _dam!.ExecQuery(db_para)!; // Abfrage ausführen
                await _appState.Log($"result_delete", data: result_delete);

                if (result_delete != null && !string.IsNullOrEmpty(result_delete.out_err)) // Resultat prüfen
                {
                    await _messageBoxService.ShowOkAsync(
                       title: _appState!.T("Error"),
                       message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {result_delete.out_err}"
                    );
                }
                if (logoutComponent != null)
                {
                    await Task.Delay(30);
                    await _appState.Log("TriggerLogoutAsync");
                    await logoutComponent.TriggerLogoutAsync();
                }
                break;
            case MessageBoxResult.No:
                if (OnChangeVisible.HasDelegate)
                {
                    await OnChangeVisible.InvokeAsync(true);
                    await Task.Delay(30);
                    StateHasChanged();
                }
                break;
            case MessageBoxResult.None:
                if (OnChangeVisible.HasDelegate)
                {
                    await OnChangeVisible.InvokeAsync(true);
                    await Task.Delay(30);
                    StateHasChanged();
                }
                break;
        }
        await _appState.Log("END [AuthenticationForm.razor] OnClick_DeleteCloudData");
    }

    private async Task OnClick_DeleteLocalData()
    {
        if (_appState?.Catalog.LocalStorage == null) return;

        // JS-LOG
        await _appState!.Log("START [AuthenticationForm.razor] OnClick_DeleteLocalData");

        if (_appState!.IsNativeApp ?? false)
        {
            var _sqLite = ServiceProvider!.GetService<BlazorCore.Services.SqLite.ISqLiteBase>();
            if (_sqLite != null)
            {
                if (OnChangeVisible.HasDelegate)
                {
                    await OnChangeVisible.InvokeAsync(false);
                    await Task.Delay(30);
                    StateHasChanged();
                }

                await Task.Delay(30);
                StateHasChanged();

                MessageBoxResult result = await _messageBoxService.ShowYesNoAsync(
                    title: _appState!.T("Confirmation"),
                    message: _appState!.T("Do you want to delete your local data (local account will also be deleted)?"),
                    yestext: @_appState!.T("Yes"),
                    notext: @_appState!.T("No")
                );

                switch (result)
                {
                    case MessageBoxResult.Yes:
                        BlazorCore.Services.SqlClient.ScalarModel resultClearAllData = await _sqLite!.ClearAllData();
                        await _appState.Log($"resultClearAllData (local)", data: resultClearAllData);
                        if (resultClearAllData != null && !string.IsNullOrEmpty(resultClearAllData.out_err))
                        {
                            await _messageBoxService.ShowOkAsync(
                               title: _appState!.T("Error"),
                               message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {resultClearAllData.out_err}"
                            );
                        }
                        if (logoutComponent != null)
                        {
                            await Task.Delay(30);
                            await _platform!.SetAsync(_appState.Catalog.LocalStorage.storagelocation, ((int)BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD).ToString());
                            _appState.UpdateStorageLocation(BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD);
                            await Task.Delay(30);
                            await _appState.Log("TriggerLogoutAsync");
                            await logoutComponent.TriggerLogoutAsync();
                        }
                        break;
                    case MessageBoxResult.No:
                        if (OnChangeVisible.HasDelegate)
                        {
                            await OnChangeVisible.InvokeAsync(true);
                            await Task.Delay(30);
                            StateHasChanged();
                        }
                        break;
                    case MessageBoxResult.None:
                        if (OnChangeVisible.HasDelegate)
                        {
                            await OnChangeVisible.InvokeAsync(true);
                            await Task.Delay(30);
                            StateHasChanged();
                        }
                        break;
                }              
            }
        }
        await _appState.Log("END [AuthenticationForm.razor] OnClick_DeleteLocalData");
    }

    private async Task OnClick_DeleteLocalDB()
    {
        if (_appState == null) return;

        // JS-LOG
        await _appState.Log("START [AuthenticationForm.razor] OnClick_DeleteLocalDB");

        if(_appState!.IsNativeApp ?? false)
        {
            var _sqLite = ServiceProvider!.GetService<BlazorCore.Services.SqLite.ISqLiteBase>();
            if (_sqLite != null)
            {
                if (OnChangeVisible.HasDelegate)
                {
                    await OnChangeVisible.InvokeAsync(false);
                    await Task.Delay(30);
                    StateHasChanged();
                }

                await Task.Delay(30);
                StateHasChanged();

                MessageBoxResult result = await _messageBoxService.ShowYesNoAsync(
                    title: _appState!.T("Confirmation"),
                    message: _appState!.T("Do you want to delete the local database (all users will be lost and you will be automatically logged out)?"),
                    yestext: @_appState!.T("Yes"),
                    notext: @_appState!.T("No")
                );

                switch (result)
                {
                    case MessageBoxResult.Yes:
                        BlazorCore.Services.SqlClient.ScalarModel resultDeleteDB = await _sqLite!.DeleteDB();
                        await _appState.Log($"resultDeleteDB (local)", data: resultDeleteDB);
                        if (resultDeleteDB != null && !string.IsNullOrEmpty(resultDeleteDB.out_err))
                        {
                            await _messageBoxService.ShowOkAsync(
                               title: _appState!.T("Error"),
                               message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {resultDeleteDB.out_err}"
                            );
                        }
                        if(resultDeleteDB != null && resultDeleteDB.out_value_bool)
                        {
                            if (logoutComponent != null)
                            {
                                await Task.Delay(30);
                                await _appState.Log("TriggerLogoutAsync");
                                await logoutComponent.TriggerLogoutAsync();
                            }
                        }
                        else
                        {
                            await _messageBoxService.ShowOkAsync(
                               title: _appState!.T("Warning"),
                               message: $"{_appState.T("The local database is locked by the operating system and could not be deleted. Delete the database manually in the directory:")} {_appState.LocalSqLiteDbPath}"
                            );
                        }
                        break;
                    case MessageBoxResult.No:
                        if (OnChangeVisible.HasDelegate)
                        {
                            await OnChangeVisible.InvokeAsync(true);
                            await Task.Delay(30);
                            StateHasChanged();
                        }
                        break;
                    case MessageBoxResult.None:
                        if (OnChangeVisible.HasDelegate)
                        {
                            await OnChangeVisible.InvokeAsync(true);
                            await Task.Delay(30);
                            StateHasChanged();
                        }
                        break;
                }                
            }
        }
        await _appState.Log("END [AuthenticationForm.razor] OnClick_DeleteLocalDB");
    }

    private async Task OnClick_DeleteAccount()
    {
        if (_appState == null) return;

        // JS-LOG
        await _appState.Log("START [AuthenticationForm.razor] OnClick_DeleteAccount");

        if (OnChangeVisible.HasDelegate)
        {
            await OnChangeVisible.InvokeAsync(false);
            await Task.Delay(30);
            StateHasChanged();
        }

        await Task.Delay(30);
        StateHasChanged();

        MessageBoxResult result = await _messageBoxService.ShowYesNoAsync(
            title: _appState!.T("Confirmation"),
            message: _appState!.T("Would you like to delete your account (cloud account and data as well as local account and data will be deleted)?"),
            yestext: @_appState!.T("Yes"),
            notext: @_appState!.T("No")
        );

        switch (result)
        {
            case MessageBoxResult.Yes:
                // Lokale DB löschen
                string err = string.Empty;
                if (_appState!.IsNativeApp ?? false)
                {
                    var _sqLite = ServiceProvider!.GetService<BlazorCore.Services.SqLite.ISqLiteBase>();
                    if (_sqLite != null)
                    {
                        BlazorCore.Services.SqlClient.ScalarModel resultDeleteDB = await _sqLite!.DeleteDB();
                        await _appState.Log($"resultDeleteDB (local)", data: resultDeleteDB);
                        if (resultDeleteDB != null && !string.IsNullOrEmpty(resultDeleteDB.out_err))
                        {
                            await _messageBoxService.ShowOkAsync(
                               title: _appState!.T("Error"),
                               message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {resultDeleteDB.out_err}"
                            );
                        }                 
                    }
                }

                // Cloud Daten und Account löschen
                if (string.IsNullOrEmpty(err))
                {
                    // Parameter setzen
                    Dictionary<string, string> db_para = new()
                    {
                        { "@Case_", "DeleteAccount" },
                        { "@UnixTS", _appState.UnixTS },
                    };
                    await _appState.Log($"db_para", data: db_para);
                    BlazorCore.Services.SqlClient.ScalarModel result_delete = await _dam!.ExecQuery(db_para)!; // Abfrage ausführen
                    await _appState.Log($"result_delete (cloud)", data: result_delete);
                    if (result_delete != null && !string.IsNullOrEmpty(result_delete.out_err)) // Resultat prüfen
                    {
                        await _messageBoxService.ShowOkAsync(
                            title: _appState!.T("Error"),
                            message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {result_delete.out_err}"
                        );
                    }
                    if (logoutComponent != null)
                    {
                        await Task.Delay(30);
                        await _appState.Log("TriggerLogoutAsync");
                        await logoutComponent.TriggerLogoutAsync();
                    }
                }
                else
                {
                    await _messageBoxService.ShowOkAsync(
                        title: _appState!.T("Error"),
                        message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {err}"
                    );
                }
                break;
            case MessageBoxResult.No:
                if (OnChangeVisible.HasDelegate)
                {
                    await OnChangeVisible.InvokeAsync(true);
                    await Task.Delay(30);
                    StateHasChanged();
                }
                break;
            case MessageBoxResult.None:
                if (OnChangeVisible.HasDelegate)
                {
                    await OnChangeVisible.InvokeAsync(true);
                    await Task.Delay(30);
                    StateHasChanged();
                }
                break;
        }
        await _appState.Log("END [AuthenticationForm.razor] OnClick_DeleteAccount");
    }

    private async Task HandleCancel()
    {
        if (OnClickCancel.HasDelegate)
            await OnClickCancel.InvokeAsync();
    }


