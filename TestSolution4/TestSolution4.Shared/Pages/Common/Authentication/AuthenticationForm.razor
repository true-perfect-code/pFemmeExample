@using Microsoft.Extensions.DependencyInjection
@using p11.UI



<P11HoverEffect HoverEffectVariant="HoverEffectVariant.ShadowLift">
    <fieldset class="mb-4 p-3 border rounded-3 bg-light">
        <legend class="float-none w-auto px-2">@_appState!.T("Action")</legend>

        <div class="d-flex flex-column gap-4">
            <!-- Logout -->
            <div class="d-flex flex-column gap-1">
                <h6>@_appState!.T("Log out of the app")</h6>
                <AuthenticationLogout @ref="_logoutComponent"
                                        Text="@_appState!.T("Logout")"
                                        CookiesToClear="@(new List<string> { _appState.Catalog.LocalStorage != null ? _appState.Catalog.LocalStorage.idp : string.Empty })"
                                        UseNativeFeatures="@(_appState.IsNativeApp ?? false)"
                                        NavigateTo="/" />
            </div>

            <!-- Passwort ändern -->
            @if (_appState != null && _appState.IdP == "tpc")
            {
                <div class="d-flex flex-column gap-1">
                    <h6>@_appState.T("User account password")</h6>
                    <AuthenticationChangePassword UseNativeFeatures="@(_appState!.IsNativeApp ?? false)" Visible="ChangePasswordVisible" />
                </div>
            }
        </div>
    </fieldset>
</P11HoverEffect>

<P11HoverEffect HoverEffectVariant="HoverEffectVariant.ShadowLift">
    <fieldset class="mb-4 p-3 border rounded-3 bg-light">
        <legend class="float-none w-auto px-2">@_appState!.T("User info")</legend>

        <div class="d-flex flex-column gap-4">
            <!-- User info -->
            <div class="d-flex flex-column gap-1">
                <AuthenticationExtend PreventPhonePreviewOpen="@(_appState!.IsPhone)" IsCancelButtonHidden="true" />
            </div>
        </div>
    </fieldset>
</P11HoverEffect>

@if (_appState != null && _appState.IdP == "tpc")
{
    <P11HoverEffect HoverEffectVariant="HoverEffectVariant.ShadowLift">

        @if (_appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD_LOCAL || _appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD)
        {
            <fieldset class="mb-4 p-3 border rounded-3 bg-light">
                <legend class="float-none w-auto px-2">@_appState!.T("2FA / Otp")</legend>

                <!-- Otp Setup -->
                <div class="d-flex flex-column gap-1">
                    <P11Button 
                        OnClick="async() => {
                            if(_appState.Is2FAActivated)
                            {
                                if (OnClick2FARevoke.HasDelegate)
                                    await OnClick2FARevoke.InvokeAsync();
                            }
                            else
                            {
                                if (OnClick2FASetup.HasDelegate)
                                    await OnClick2FASetup.InvokeAsync();
                            }
                        }" 
                        Text="@_appState.T(_appState.Is2FAActivated ? "2FA-Revoke" : "2FA-Setup")" 
                        CssClass="flex-fill" />
                </div>
            </fieldset>
        }

        @if (_appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD_LOCAL || _appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL)
        {
            <fieldset class="mb-4 p-3 border rounded-3 bg-light">
                <legend class="float-none w-auto px-2">@_appState!.T("PIN")</legend>

                <!-- Pin Setup -->
                <div class="d-flex flex-column gap-1">
                    <AuthenticationChangePin UseNativeFeatures="@(_appState!.IsNativeApp ?? false)" Visible="ChangePinVisible" />
                </div>
            </fieldset>
        }

    </P11HoverEffect>
}

<P11HoverEffect HoverEffectVariant="HoverEffectVariant.ShadowLift">
    <fieldset class="mb-4 p-3 border rounded-3 bg-light">
        <legend class="float-none w-auto px-2">@_appState!.T("GDPR")</legend>

        @* <div class="alert alert-dange mt-1 pt-2 pb-0">
            <P11Checkbox Value="@pE.Utility.Appl.IsInspectionEnabled"
                            ValueChanged="@((bool isChecked) => {
                                // Ispection in WebView aktivieren
                                pE.Utility.Appl.IsInspectionEnabled = isChecked;

                                pE.Utility.HostBridge.RaiseInspectionChanged(isChecked);
                            })"
                            Label="Enable browser inspection (F12) and developer options (see new menu item Administration)."
                            IsSwitch="true" />
        </div> *@

        <!-- GDPR/DSGVO -->
        <div class="d-flex flex-column gap-1">
            <P11AccordionNative CssClass="p-0">
                <Title>
                    <span>@_appState.T("Expand GDPR")</span>
                </Title>
                <ChildContent>
                    <div class="d-flex flex-column gap-1">
                        <P11AccordionNative HeaderBackgroundVariant="BackgroundVariant.Info">
                            <Title>
                                <span>@_appState.T("Delete Cookies")</span>
                            </Title>
                            <ChildContent>
                                @* <div class="container mt-2">
                                    <table class="table table-striped table-hover">
                                        <thead>
                                            <tr>
                                                <th scope="col">@_appState.T("Cookies")</th>
                                                <th scope="col"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (cookies != null)
                                            {
                                                @foreach (var cookie in cookies)
                                                {
                                                    <tr>
                                                        <td class="text-break">@cookie.Key : <b>@cookie.Value</b></td>
                                                        <td class="text-end">
                                                            <P11Button AriaLabel="@($"{_appState.T("Delete cookie")} {cookie.Key}")"
                                                                        ButtonVariant="ButtonVariant.Danger"
                                                                        OnClick="async() => {
                                                                            await _platform!.RemoveAsync(cookie.Key);
                                                                            await LoadCookies();
                                                                            StateHasChanged();
                                                                        }"
                                                                        IsDisabled="@(cookie.Value == "******")"
                                                                        IconClass="bi bi-trash" />
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                <div class="mb-3">
                                    <P11Button OnClick="OnClick_DeleteAllCookies" Text="@_appState.T("Delete all cookies")" />
                                </div> *@

                                <AuthenticationCookies 
                                    OnLogout="async() => {
                                        if (_logoutComponent != null)
                                            await _logoutComponent.TriggerLogoutAsync();
                                    }" 
                                    OnChangeVisibleCookies="OnChangeVisible" />
                                
                            </ChildContent>
                        </P11AccordionNative>
                        <P11Button Text="@_appState.T("Delete cloud data")" OnClick="OnClick_DeleteCloudData" IsDisabled="@(_appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL)" />
                        <P11Button Text="@_appState.T("Delete local data")" OnClick="OnClick_DeleteLocalData" IsDisabled="@(_appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD || !_appState.HasIsNativeApp())" />
                        <P11Button Text="@_appState.T("Delete local account")" OnClick="OnClick_DeleteLocalDB" IsDisabled="@( _appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.CLOUD || !_appState.HasIsNativeApp())" />
                        <P11Button Text="@_appState.T("Delete cloud/local account")" OnClick="OnClick_DeleteAccount" IsDisabled="@(_appState.StorageLocation == BlazorCore.Services.AppState.STORAGE_LOCATION.LOCAL)" ButtonVariant="ButtonVariant.Warning" />
                    </div>

                    <AuthenticationLogout @ref="logoutComponent"
                                            IsButtonHidden="true"
                                            UseNativeFeatures="@(_appState.IsNativeApp ?? false)" />
                </ChildContent>
            </P11AccordionNative>
        </div>
    </fieldset>
</P11HoverEffect>

@if(_appState != null && !_appState.IsPhone)
{
    <div class="d-flex w-100 gap-4 mt-4">
        <P11Button Text="@_appState!.T("Close")" OnClick="HandleCancel" ButtonVariant="ButtonVariant.Secondary" CssClass="flex-fill" />
    </div>
}


