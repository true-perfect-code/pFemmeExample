@* 

Anleitung zur Server-Blazor Implementierung 
1. Im Web-Projekt das Verzeichnis 'wwwroot' erstellen, falls nicht vorhanden
2. JavaScript Datei 'blazor-connectivity.js' erstellen und folgendne Inhalt einfügen:
    window.initializeOnlineOfflineMonitor = function () {
        const icon = document.getElementById('tpc-internet-status-icon');
        const text = document.getElementById('tpc-internet-status-text');

        function updateStatus() {
            if (navigator.onLine) {
                icon.className = 'bi bi-globe-americas text-success fs-6';
                text.textContent = 'Connected';
                text.className = 'ms-2 badge text-bg-success d-none d-lg-inline';
            } else {
                icon.className = 'bi bi-slash-circle-fill text-danger fs-6';
                text.textContent = 'Offline';
                text.className = 'ms-2 badge text-bg-danger d-none d-lg-inline';
            }
        }

        window.addEventListener('online', updateStatus);
        window.addEventListener('offline', updateStatus);
        updateStatus(); // Initialstatus setzen
    };
3. Blazor Server applikation testen.
