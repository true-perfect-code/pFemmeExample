@code {
    [Inject] private BlazorCore.Services.AppState.IAppStateBase _appState { get; set; } = default!;
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Nur in Blazor Server: Browser-Monitor aktivieren
            if (_appState != null && _appState.IsNativeApp != null && _appState.IsNativeApp.Value == false)
                await JSRuntime.InvokeVoidAsync("initializeOnlineOfflineMonitor");
        }
    }

    protected override void OnInitialized()
    {
        if (_appState.IsNativeApp ?? false)
        {
            // Nur in MAUI: mit AppState synchronisieren
            AppState.OnChange += StateHasChanged;
        }
    }

    private string GetStatusTitle()
        => (_appState.IsNativeApp ?? false)
            ? (AppState.IsInternetConnected ? _appState.T("Connected to the Internet") : _appState.T("Offline"))
            : _appState.T("Browser Connection Status");

    public void Dispose()
    {
        if (_appState.IsNativeApp ?? false)
            AppState.OnChange -= StateHasChanged;
    }
}
