@code {
    [Inject]
    private BlazorCore.Services.AppState.IAppStateBase _appState { get; set; } = default!;

    [Parameter] public bool UseNativeFeatures { get; set; } = false;

    protected override void OnInitialized()
    {
        // Abonniere das zentrale Event:
        // Wenn der AppState (durch das MAUI-Event) das Signal sendet,
        // ruft Blazor StateHasChanged() auf und die Komponente rendert neu.
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
