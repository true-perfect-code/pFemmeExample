@using System.Text
@using Microsoft.JSInterop
@using p11.UI


<!-- EXPORT / IMPORT TOGGLE (Radio Button Group using btn-check) -->
<P11HoverEffect HoverEffectVariant="HoverEffectVariant.ShadowLift">
    <fieldset class="mb-4 p-3 border rounded-3 bg-light">
        <legend class="float-none w-auto px-2">@_appState!.T("Action")</legend>

        <P11ButtonRadio TValue="string"
                        @bind-Value="SelectedAction"
                        ButtonVariant="@ButtonVariant.Primary"
                        CssClassGroup="w-100"
                        ButtonSize="@Size.Medium">
            <div class="d-flex w-100 gap-3">
                <P11ButtonRadioOption TValue="string" Value="@("export")" Text="@_appState!.T("Export")" IconClass="bi bi-upload me-2" CssClass="flex-fill" />
                <P11ButtonRadioOption TValue="string" Value="@("import")" Text="@_appState!.T("Import")" IconClass="bi bi-download me-2" CssClass="flex-fill" />
            </div>
        </P11ButtonRadio>

    </fieldset>
</P11HoverEffect>

@switch (SelectedAction)
{
    case "export":
        <!-- 1. EXPORT SECTION (Visible by default) -->
        <div id="exportSection" class="" aria-live="polite">

            <!-- Export Format Selection (CSV, JSON, XML) -->
            <P11HoverEffect HoverEffectVariant="HoverEffectVariant.ShadowLift">
                <fieldset class="mb-4 p-3 border rounded-3 bg-light">
                    <legend class="float-none w-auto px-2">@_appState!.T("Export format")</legend>

                    <P11ButtonRadio TValue="string"
                                    @bind-Value="SelectedFormat"
                                    ButtonVariant="@ButtonVariant.Primary"
                                    CssClassGroup="w-100"
                                    ButtonSize="@Size.Medium">
                        <div class="d-flex w-100 gap-3">
                            <P11ButtonRadioOption TValue="string" Value="@("csv")" Text="@_appState!.T("CSV")" IconClass="bi bi-filetype-csv me-2" CssClass="flex-fill" />
                            <P11ButtonRadioOption TValue="string" Value="@("json")" Text="@_appState!.T("JSON")" IconClass="bi bi-filetype-json me-2" CssClass="flex-fill" />
                            <P11ButtonRadioOption TValue="string" Value="@("xml")" Text="@_appState!.T("XML")" IconClass="bi bi-filetype-xml me-2" CssClass="flex-fill" />
                        </div>
                    </P11ButtonRadio>

                </fieldset>
            </P11HoverEffect>

            <!-- CSV DELIMITER & TABLE SELECTION -->
            <P11HoverEffect HoverEffectVariant="HoverEffectVariant.ShadowLift">
                <fieldset class="p-3 border rounded-3 mb-4 bg-light">
                    <legend class="float-none w-auto px-2">@_appState!.T("Export details")</legend>

                    @if (SelectedFormat.ToLower().Contains("csv"))
                    {
                        <P11Label class="form-label fw-semibold">@_appState!.T("CSV delimiter")</P11Label>
                        <P11Radio TValue="string"
                                  @bind-Value="SelectedSeparator"
                                  Name="CSVdelimiterRadio"
                                  CssClass="mb-3">
                            <div class="d-flex flex-wrap gap-3">
                                <P11RadioOption TValue="string" Value="@(";")" Text="@(_appState!.T("Semicolon") + "(;)")" />
                                <P11RadioOption TValue="string" Value="@(",")" Text="@(_appState!.T("Comma") + "(,)")" />
                                <P11RadioOption TValue="string" Value="@("\t")" Text="@(_appState!.T("Tabulator") + "(\t)")" />
                            </div>
                        </P11Radio>
                    }

                    <!-- Export Table Selection -->
                    <div class="mb-3">
                        @if (AvailableTables != null)
                        {
                            <label for="exportTable" class="form-label fw-semibold">@_appState!.T("Table(s) for export")</label>
                            <P11Select TItem="TableModel" TValue="string"
                                       @bind-Value="SelectedTable"
                                       Items="AvailableTables"
                                       ItemValueExpression="p => p.Id"
                                       ItemTextExpression="p => p.Name"
                                       PlaceholderText="@_appState!.T("-- Please select --")"
                                       AriaLabel="@_appState!.T("Select table dropdown")"
                                       CssClass="form-select-lg" />
                        }
                    </div>
                </fieldset>
            </P11HoverEffect>

            <!-- Export Button -->
            @* <div class="d-grid">
                <P11Button IsDisabled="@(string.IsNullOrEmpty(SelectedTable))" OnClick="OnClickExport" Text="@_appState!.T("Export")" ButtonVariant="ButtonVariant.Success" />
            </div> *@
        </div>
        break;

    default:
        <!-- 2. IMPORT SECTION (Hidden by default) -->
        <div id="importSection" aria-live="polite">

            <!-- Instructions and Info Button -->
            <div class="d-flex justify-content-between align-items-center mb-2">
                <label for="importDataArea" class="form-label fw-semibold mb-0">
                    @_appState!.T("Insert import data")
                </label>
            </div>

            <!-- Import Description -->
            <div class="alert alert-warning py-2 small mb-3">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                @_appState!.T("Please ensure that the data structure is correct (headers, tasks, separation, etc.). Further information can be found in the documentation.")
            </div>

            <!-- Textarea for Data Input -->
            @* <textarea class="form-control" id="importDataArea" rows="12" placeholder="Fügen Sie hier Ihre exportierten Daten ein..."></textarea> *@
            <P11Textarea TValue="string"
                         Placeholder="@_appState!.T("Todo: Task1, Task2, Task3")"
                         ShowDevelopmentErrors="false"
                         Rows="6"
                         @bind-Value="ImportData" />

            <!-- Import Button -->
            @* <div class="d-grid mt-4">
                <P11Button IsDisabled="@(string.IsNullOrEmpty(ImportData))" OnClick="OnClickImport" Text="@_appState!.T("Import")" ButtonVariant="ButtonVariant.Success" />
            </div> *@
        </div>
        break;
}


@if (_appState != null && !_appState!.IsPhone)
{
    <div class="d-flex w-100 gap-4 mt-4">
        @switch (SelectedAction)
        {
            case "export":
                <P11Button IsDisabled="@(string.IsNullOrEmpty(SelectedTable))" OnClick="OnClickExport" Text="@_appState!.T("Export")" ButtonVariant="ButtonVariant.Success" CssClass="flex-fill" />
                break;

            default:
                <P11Button IsDisabled="@(string.IsNullOrEmpty(ImportData))" OnClick="OnClickImport" Text="@_appState!.T("Import")" ButtonVariant="ButtonVariant.Success" CssClass="flex-fill" />
                break;
        }
        <P11Button Text="@_appState!.T("Close")" OnClick="HandleCancel" ButtonVariant="ButtonVariant.Secondary" CssClass="flex-fill" />
    </div>
}


