    private async Task GenerateXmlStream(List<List<string>> data, Stream stream)
    {
        try
        {
            if (data == null || data.Count == 0) return;

            var headers = data.First();
            var rows = data.Skip(1);

            // Änderung: UTF8Encoding(false) stellt sicher, dass kein BOM am Dateianfang steht.
            var encodingWithoutBom = new System.Text.UTF8Encoding(false);
            using var writer = new StreamWriter(stream, encodingWithoutBom, leaveOpen: true);
            using var xml = System.Xml.XmlWriter.Create(writer, new System.Xml.XmlWriterSettings
            {
                Indent = true,
                Encoding = encodingWithoutBom, // Muss mit dem StreamWriter übereinstimmen
                Async = true
            });

            xml.WriteStartDocument();
            xml.WriteStartElement(SelectedTable); 

            foreach (var row in rows)
            {
                xml.WriteStartElement("Row");
                for (int i = 0; i < headers.Count; i++)
                {
                    string columnName = System.Xml.XmlConvert.EncodeName(headers[i]);
                    string value = i < row.Count ? row[i] : string.Empty;
                    xml.WriteElementString(columnName, value);
                }
                xml.WriteEndElement(); 
            }

            xml.WriteEndElement(); 
            xml.WriteEndDocument();
            await xml.FlushAsync();
            await writer.FlushAsync();
        }
        catch (Exception ex)
        {
            await _messageBoxService.ShowOkAsync(
                title: _appState!.T("Error"),
                message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
            );
        }
    }

    private string EscapeCsvField(string cell, string separator)
    {
        try
        {
            if (!string.IsNullOrEmpty(cell) && (cell.Contains(separator) || cell.Contains('\n') || cell.Contains('"')))
            {
                return "\"" + cell.Replace("\"", "\"\"") + "\"";
            }
            return cell ?? string.Empty;
        }
        catch (Exception ex)
        {
            _messageBoxService.ShowOkAsync(
                title: _appState!.T("Error"),
                message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
            );
            return string.Empty;
        }
    }

    private async Task HandleCancel()
    {
        if (OnClickCancel.HasDelegate)
        {
            await OnClickCancel.InvokeAsync();
        }
    }

