    private const string TableIdentifierPrefix = "[TABLE-NAME]:";


    protected override async Task OnInitializedAsync()
    {
        // Wir "registrieren" die HandleSave-Methode beim Parent (Modal)
        if (OnProvideSaveAction.HasDelegate)
        {
            await OnProvideSaveAction.InvokeAsync(OnClickExportImport);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await Task.Delay(10);

        if (HideExportPanel)
            SelectedAction = "import";

        ParsedTables.Clear();

        if(AvailableTables == null)
            AvailableTables = new List<TableModel>();
        AvailableTables.Clear(); 

        string currentTableName = string.Empty;

        if (DataContainer.Any())
        {
            foreach (var row in DataContainer)
            {
                if (row.Count == 0) continue;

                string firstCell = row[0];

                if (firstCell.StartsWith(TableIdentifierPrefix, StringComparison.OrdinalIgnoreCase))
                {
                    currentTableName = firstCell.Substring(TableIdentifierPrefix.Length).Trim();
                    AvailableTables.Add(new TableModel
                    {
                        Id = currentTableName,
                        Name = currentTableName
                    });
                    ParsedTables[currentTableName] = new List<List<string>>();
                }
                else if (!string.IsNullOrEmpty(currentTableName))
                {
                    ParsedTables[currentTableName].Add(row);
                }
            }
        }
    }

    private async Task OnClickExportImport()
    {
        switch (SelectedAction)
        {
            case "export":
                await OnClickExport();
                break;

            default:
                await OnClickImport();
                break;
        }
    }

    private async Task OnClickExport()
    {
        try
        {
            List<List<string>> dataToExport = GetExportData();

            if (dataToExport.Count == 0)
            {
                await _messageBoxService.ShowOkAsync(
                    title: _appState!.T("Info"),
                    message: _appState.T(_appState.T("There is no data!"))
                );
                return;
            }

            // Plattform-spezifische Pfad-Logik
            string pathNativ = await _platform!.DirectoryPicker() ?? "";
            bool isNative = _appState!.IsNativeApp ?? false;
            string filename = $"{SelectedTable}_{DateTime.Now:yyyyMMdd_HHmmss}";

            // Pfad-Kombination nur für WPF (Windows Client)
            filename = (isNative && _platform.GetCurrPlatform() == BlazorCore.Services.Platform.PLATFORMS.WINDOWS_CLIENT 
                        ? Path.Combine(pathNativ, filename) : filename);

            using Stream stream = new MemoryStream();
            string fileExtension = string.Empty;

            if (SelectedFormat == "csv")
            {
                await GenerateCsvStream(dataToExport, SelectedSeparator, stream);
                fileExtension = "csv";
            }
            else if (SelectedFormat == "json")
            {
                await GenerateJsonStream(dataToExport, stream);
                fileExtension = "json";
            }
            else if (SelectedFormat == "xml")
            {
                await GenerateXmlStream(dataToExport, stream);
                fileExtension = "xml";
            }

            filename += "." + fileExtension;

            if (stream.Length > 0)
            {
                stream.Position = 0;
                try
                {
                    // Zentraler Aufruf an den Plattform-Service
                    var result = await _platform!.SaveFileNativeAsync(filename, stream, pathNativ);

                    if (!result.out_value_bool)
                    {
                        await _messageBoxService.ShowOkAsync(
                            title: _appState!.T("Error"),
                            message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {result.out_err}"
                        );
                        return;
                    }
                }
                catch (Exception ex)
                {
                    await _messageBoxService.ShowOkAsync(
                        title: _appState!.T("Error"),
                        message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
                    );
                    return; 
                }
            }

            await _toastService!.ShowSuccessAsync(_appState.T("The data has been successfully exported."), _appState.T("Success"), position: ToastPosition.BottomEnd, durationMs: 3000);
        }
        catch (Exception ex)
        {
            await _messageBoxService.ShowOkAsync(
                title: _appState!.T("Error"),
                message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
            );
        }
    }

    private async Task OnClickImport()
    {
        try
        {
            if(string.IsNullOrEmpty(ImportData))
            {
                await _messageBoxService.ShowOkAsync(
                   title: _appState!.T("Info"),
                   message: _appState.T(_appState.T("There is no data!"))
                );
                return;
            }
            
            if (OnImport.HasDelegate)
            {
                await OnImport.InvokeAsync(ImportData);
            }
        }
        catch (Exception ex)
        {
            await _messageBoxService.ShowOkAsync(
                title: _appState!.T("Error"),
                message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
            );
        }
    }

    public List<List<string>> GetExportData()
    {
        try
        {
            if (string.IsNullOrEmpty(SelectedTable)) return new List<List<string>>();

            if (ParsedTables.ContainsKey(SelectedTable))
            {
                return ParsedTables[SelectedTable];
            }
            return new List<List<string>>();
        }
        catch (Exception ex)
        {
            _messageBoxService.ShowOkAsync(
                title: _appState!.T("Error"),
                message: $"{_appState.T(_globalState != null ? _globalState != null ? _globalState.ConfigGeneral.ErrorText : "We’re sorry, but an error occurred!" : "We’re sorry, but an error occurred!")} {BlazorCore.ErrorHelper.GetErrorContext(ex.Message)}"
            );
            return new List<List<string>>();
        }
    }

