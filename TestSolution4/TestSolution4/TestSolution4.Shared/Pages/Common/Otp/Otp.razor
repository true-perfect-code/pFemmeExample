            { "@PasswordHash", PasswordHash ?? string.Empty },
            { "@Scope", "set" },
            { DB_CMD.NO_CLOUD, string.Empty }
        };

        return await _dam!.Scalar(db_para)!;
    } *@

    private async Task HandleRevoke2FA()
    {
        _resetErrorMessage = null;

        // Wir nutzen die komponente nur um Benutzereingaben durchzuführen. Eigentliche prüfung erfolgt dann auf dem Server
        (string OtpUserDigitInput, string OtpBackupCode, string Account, string Password) result = (string.Empty, _otpParametersForm.OtpBackupCode, _otpParametersForm.Account, _otpParametersForm.Password);
        if (OnSecretEnteredAction is not null)
        {
            // Service-Variante (direkter Callback)
            OnSecretEnteredAction.Invoke(result);
        }
        else if (OnSecretEntered.HasDelegate)
        {
            // UI-Variante (Parent Razor-Komponente)
            await OnSecretEntered.InvokeAsync(result);
        }
    }

    public void Dispose()
    {
        inputRefs = null!;
    }
}